@page
@model LoginModel

@{
    ViewData["Title"] = "Log in";
}

<style>
    .login-background {
        min-height: calc(100vh - 80px);
        width: 100vw;
        margin-left: calc(50% - 50vw);
        display: flex;
        align-items: flex-start;
        justify-content: center;
        padding: 35px 15px 20px;
        background: #ffffff;
    }

    .login-card {
        width: 100%;
        max-width: 390px;
        padding: 24px 28px;
        background: #ffffff;
        border-radius: 14px;
        box-shadow: 0 14px 35px rgba(0, 0, 0, 0.14);
    }

        .login-card h1 {
            text-align: center;
            font-size: 1.7rem;
            font-weight: 500;
            color: #2f2f38;
            margin-bottom: 6px;
        }

    .login-line {
        width: 45px;
        height: 2px;
        background-color: #d71920;
        margin: 10px auto 20px;
    }

    form {
        margin-top: 0;
    }

    .floating-group {
        position: relative;
        margin-bottom: 13px;
    }

    .login-card .form-control {
        width: 100%;
        height: 50px;
        padding: 16px 14px 6px;
        border-radius: 7px;
        border: 1.5px solid #d6d6d6;
        color: #333333;
        background-color: #ffffff;
        font-size: 0.92rem;
        outline: none;
    }

        .login-card .form-control:focus {
            border-color: #b71920;
            box-shadow: 0 0 0 1px rgba(183, 25, 32, 0.35);
        }

    .login-card .form-label {
        position: absolute;
        left: 12px;
        top: 14px;
        padding: 0 5px;
        background: #ffffff;
        color: #777777;
        font-size: 0.92rem;
        pointer-events: none;
        transition: 0.18s ease;
        margin: 0;
    }

    .login-card .form-control:focus + .form-label,
    .login-card .form-control:not(:placeholder-shown) + .form-label {
        top: -8px;
        font-size: 0.78rem;
        color: #b71920;
    }

    .login-card .text-danger {
        display: block;
        font-size: 0.78rem;
        margin-top: 3px;
    }

    .remember-me {
        display: flex;
        align-items: center;
        gap: 8px;
        color: #777777;
        font-size: 0.9rem;
        margin: 4px 0 15px;
    }

        .remember-me .form-check-input {
            margin: 0;
            border-color: #d6d6d6;
        }

            .remember-me .form-check-input:checked {
                background-color: #b71920;
                border-color: #b71920;
            }

    .login-btn {
        width: 100%;
        height: 48px;
        border: none;
        border-radius: 7px;
        background-color: #b71920;
        color: white;
        font-size: 1rem;
        font-weight: 500;
        margin-top: 4px;
    }

        .login-btn:hover {
            background-color: #9f151b;
        }

    .login-link-text {
        text-align: center;
        margin-top: 16px;
        margin-bottom: 0;
        color: #8a8a8a;
        font-size: 0.9rem;
    }

        .login-link-text a {
            color: #b71920;
            text-decoration: none;
            font-weight: 500;
        }

        .login-link-text p {
            margin-bottom: 6px;
        }

    .validation-summary-errors ul {
        list-style: none;
        padding-left: 0;
        margin: 0 0 12px 0;
    }

    .validation-summary-errors li {
        margin: 0;
        font-size: 0.85rem;
    }
</style>

<div class="login-background">
    <div class="login-card">
        <h1>Log in</h1>
        <div class="login-line"></div>

        <form id="account" method="post">
            <div asp-validation-summary="ModelOnly" class="text-danger" role="alert"></div>

            <div class="floating-group">
                <input asp-for="Input.Email"
                       class="form-control"
                       autocomplete="username"
                       aria-required="true"
                       placeholder=" " />
                <label asp-for="Input.Email" class="form-label">Email*</label>
                <span asp-validation-for="Input.Email" class="text-danger"></span>
            </div>

            <div class="floating-group">
                <input asp-for="Input.Password"
                       class="form-control"
                       autocomplete="current-password"
                       aria-required="true"
                       placeholder=" " />
                <label asp-for="Input.Password" class="form-label">Password*</label>
                <span asp-validation-for="Input.Password" class="text-danger"></span>
            </div>

            <label asp-for="Input.RememberMe" class="remember-me">
                <input class="form-check-input" asp-for="Input.RememberMe" />
                @Html.DisplayNameFor(m => m.Input.RememberMe)
            </label>

            <button id="login-submit" type="submit" class="login-btn">
                Log in
            </button>

            <div class="login-link-text">
                <p>
                    <a id="forgot-password" asp-page="./ForgotPassword">Forgot password?</a>
                </p>

                <p>
                    Don't have an account?
                    <a asp-page="./Register" asp-route-returnUrl="@Model.ReturnUrl">Register</a>
                </p>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}