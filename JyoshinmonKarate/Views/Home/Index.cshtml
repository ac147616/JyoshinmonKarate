@{
    ViewData["Title"] = "Home";
}


<style>
    main.pb-3 {
        padding-bottom: 0 !important;
    }

    .container {
        margin-bottom: 0 !important;
    }

    body {
        margin-bottom: 0 !important;
    }

    .guest-hero {
        text-align: center;
        padding: 15px 0 0px;
        overflow: hidden;
    }

    .guest-hero h1 {
        color: #111;
        font-size: 3rem;
        font-weight: 800;
        line-height: 1.05;
        margin-bottom: 20px;
    }

    .guest-hero p {
        color: #373544;
        max-width: 650px;
        margin: 0 auto 20px;
        font-size: 1rem;
        line-height: 1.6;
    }

    .hero-buttons {
        margin-bottom: 30px;
    }

        .hero-buttons a {
            display: inline-block;
            text-decoration: none;
            padding: 12px 26px;
            margin: 0 8px;
            border-radius: 999px;
            font-weight: 600;
        }

    .primary-btn {
        background-color: #d71920;
        color: white;
        box-shadow: 0 8px 18px rgba(215, 25, 32, 0.25);
    }

    .secondary-btn {
        background-color: white;
        color: #373544;
        border: 1px solid #ddd;
    }

    .scene,
    .a3d {
        display: grid;
    }

    .scene {
        width: 100vw;
        height: 380px;
        margin-top: -100px;
        margin-left: calc(50% - 50vw);
        overflow: hidden;
        perspective: 1600px;
        mask: linear-gradient(90deg, transparent, black 12%, black 88%, transparent);
    }

    .a3d {
        place-self: center;
        transform-style: preserve-3d;
        animation: rotateCarousel 32s linear infinite;
    }

    @@keyframes rotateCarousel {
        to {
            transform: rotateY(360deg);
        }
    }

    .card {
        --w: 165px;
        --ba: calc(1turn / var(--n));
        grid-area: 1 / 1;
        width: var(--w);
        aspect-ratio: 7 / 10;
        object-fit: cover;
        border-radius: 24px;
        backface-visibility: hidden;
        transform: rotateY(calc(var(--i) * var(--ba))) translateZ(-590px);
    }

</style>

@{
    ViewData["Title"] = "Home";

    var carouselImages = new[]
    {
        "carousel1.jpg",
        "carousel2.jpg",
        "carousel3.jpg",
        "carousel4.jpg",
        "carousel5.jpg",
        "carousel6.jpg",
        "carousel7.jpg",
        "carousel8.jpg",
        "carousel9.jpg",
        "carousel10.jpg"
    };
}

@if (User.Identity?.IsAuthenticated != true)
{
    <section class="guest-hero">
        <h1>
            Manage Your Karate<br />
            Journey in One Place
        </h1>
        <p>
            A simple online portal for Jyoshinmon Karate members, parents, instructors, and administrators
            to view schedules, attendance, grading progress.
        </p>

        <div class="hero-buttons">
            <a class="primary-btn" asp-area="Identity" asp-page="/Account/Register">
                Register
            </a>

            <a class="secondary-btn" asp-area="Identity" asp-page="/Account/Login">
                Login
            </a>
        </div>

        <div class="scene">
            <div class="a3d" style="--n:@(carouselImages.Length * 2)">

                @for (int repeat = 0; repeat < 2; repeat++)
                {
                    for (int i = 0; i < carouselImages.Length; i++)
                    {
                        <img class="card"
                             src="~/images/@carouselImages[i]"
                             style="--i:@(repeat* carouselImages.Length + i)"
                             alt="Karate Image" />
                    }
                }

            </div>
        </div>
    </section>
}