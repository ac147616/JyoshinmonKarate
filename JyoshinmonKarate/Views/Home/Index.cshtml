@{
    ViewData["Title"] = "Home Page";
}

<style>
    .welcome-carousel {
        border: 6px solid white;
        box-shadow: 0 8px 22px rgba(0, 0, 0, 0.25);
        background-color: white;
    }

    .welcome-carousel .carousel-control-prev-icon,
    .welcome-carousel .carousel-control-next-icon {
        background-color: rgba(0, 0, 0, 0.65);
        border-radius: 50%;
        padding: 22px;
    }
</style>

@if (!User.Identity.IsAuthenticated){
    <div class="row mt-5">
        <div class="col-md-6">
            <div id="welcomePageCarousel" class="carousel slide welcome-carousel"
                 data-bs-ride="carousel" data-bs-interval="3000">
                <div class="carousel-inner">
                    <div class="carousel-item active">
                        <img src="~/images/carousel1.jpg" class="d-block w-100"
                             style="height: 300px; object-fit: cover; object-position: center;" alt="">
                    </div>
                    <div class="carousel-item">
                        <img src="~/images/carousel2.jpg" class="d-block w-100"
                             style="height: 300px; object-fit: cover; object-position: center;" alt="">
                    </div>
                    <div class="carousel-item">
                        <img src="~/images/carousel3.jpg" class="d-block w-100"
                             style="height: 300px; object-fit: cover; object-position: center;" alt="">
                    </div>
                    <div class="carousel-item">
                        <img src="~/images/carousel4.jpg" class="d-block w-100"
                             style="height: 300px; object-fit: cover; object-position: center;" alt="">
                    </div>
                    <div class="carousel-item">
                        <img src="~/images/carousel5.jpg" class="d-block w-100"
                             style="height: 300px; object-fit: cover; object-position: center;" alt="">
                    </div>
                    <div class="carousel-item">
                        <img src="~/images/carousel6.jpg" class="d-block w-100"
                             style="height: 300px; object-fit: cover; object-position: center;" alt="">
                    </div>
                    <div class="carousel-item">
                        <img src="~/images/carousel7.jpg" class="d-block w-100"
                             style="height: 300px; object-fit: cover; object-position: center;" alt="">
                    </div>
                    <div class="carousel-item">
                        <img src="~/images/carousel8.jpg" class="d-block w-100"
                             style="height: 300px; object-fit: cover; object-position: center;" alt="">
                    </div>
                    <div class="carousel-item">
                        <img src="~/images/carousel9.jpg" class="d-block w-100"
                             style="height: 300px; object-fit: cover; object-position: center;" alt="">
                    </div>
                    <div class="carousel-item">
                        <img src="~/images/carousel10.jpg" class="d-block w-100"
                             style="height: 300px; object-fit: cover; object-position: center;" alt="">
                    </div>
                </div>
                <button class="carousel-control-prev" type="button"
                        data-bs-target="#welcomePageCarousel" data-bs-slide="prev">
                    <span class="carousel-control-prev-icon" aria-hidden="true"></span>
                    <span class="visually-hidden">Previous</span>
                </button>
                <button class="carousel-control-next" type="button"
                        data-bs-target="#welcomePageCarousel" data-bs-slide="next">
                    <span class="carousel-control-next-icon" aria-hidden="true"></span>
                    <span class="visually-hidden">Next</span>
                </button>
            </div>
        </div>

        <div class="col-md-6 d-flex flex-column justify-content-center">
            <h1 style="color: #373544;">Jyoshinmon Karate</h1>
            <p style="color: #373544;">Welcome to the Jyoshinmon Karate Club management system.</p>
            <p style="color: #373544;">
                Our club has been training members across Auckland for many years,
                offering classes for all ages and skill levels from White Belt through to Black Belt.
            </p>
            <p style="color: #373544;">
                Use the navigation above to manage members, schedules,
                gradings, and more.
            </p>
        </div>
    </div>
}