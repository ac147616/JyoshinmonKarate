@model List<JyoshinmonKarate.Models.Member>

@{
    ViewData["Title"] = "Home";

    var carouselImages = new[]
    {
        "carousel1.jpg",
        "carousel2.jpg",
        "carousel3.jpg",
        "carousel4.jpg",
        "carousel5.jpg",
        "carousel6.jpg",
        "carousel7.jpg",
        "carousel8.jpg",
        "carousel9.jpg",
        "carousel10.jpg"
    };
}

@section Styles {
    <link rel="stylesheet" href="~/css/home.css" asp-append-version="true" />
}

@if (User.Identity?.IsAuthenticated != true)
{
    <section class="guest-hero">
        <h1>
            Manage Your Karate<br />
            Journey in One Place
        </h1>
        <p>
            A simple online portal for Jyoshinmon Karate members, parents, instructors, and administrators
            to view schedules, attendance, grading progress.
        </p>

        <div class="hero-buttons">
            <a class="primary-btn" asp-area="Identity" asp-page="/Account/Register">
                Register
            </a>

            <a class="secondary-btn" asp-area="Identity" asp-page="/Account/Login">
                Login
            </a>
        </div>

        <div class="scene">
            <div class="a3d" style="--n:@(carouselImages.Length * 2)">

                @for (int repeat = 0; repeat < 2; repeat++)
                {
                    for (int i = 0; i < carouselImages.Length; i++)
                    {
                        <img class="card"
                             src="~/images/@carouselImages[i]"
                             style="--i:@(repeat* carouselImages.Length + i)"
                             alt="Karate Image" />
                    }
                }

            </div>
        </div>
    </section>
}

@if (User.Identity != null && User.Identity.IsAuthenticated && User.IsInRole("User"))
{
    <section class="member-home">
        <div class="member-home-top">
            <div>
                <h1>My Members</h1>
                <p>Select a member to manage their profile, attendance, payments, and progress.</p>
            </div>

            <a class="add-member-btn"
                   asp-controller="Members"
                   asp-action="Create">
                <i class="bi bi-person-plus"></i>
                Add Member
            </a>
        </div>

        @if (Model != null && Model.Count > 0)
        {
            <div class="member-carousel-wrap">
                <button class="carousel-arrow left-arrow" type="button" onclick="scrollMembers(-1)">
                    <i class="bi bi-chevron-left"></i>
                </button>

                <div class="member-carousel" id="memberCarousel">
                    @foreach (var member in Model)
                    {
                        <div class="member-card-box">

                            <div class="member-avatar">
                                @if (!string.IsNullOrEmpty(member.ProfilePhotoPath))
                                {
                                    <img src="@member.ProfilePhotoPath" alt="@member.FirstName" />
                                }
                                else
                                {
                                    <i class="bi bi-person-fill"></i>
                                }
                            </div>

                            <div class="member-name-row">
                                <h2>@member.FirstName @member.LastName</h2>

                                <div class="dropdown">
                                    <button class="member-menu-btn"
                                            type="button"
                                            data-bs-toggle="dropdown"
                                            aria-expanded="false">
                                        <i class="bi bi-three-dots-vertical"></i>
                                    </button>

                                    <ul class="dropdown-menu dropdown-menu-end member-dropdown-menu">
                                        <li>
                                            <a class="dropdown-item"
                                                   asp-controller="Members"
                                                   asp-action="Edit"
                                                   asp-route-id="@member.MemberId">
                                                <i class="bi bi-pencil-square"></i>
                                                Edit member
                                            </a>
                                        </li>

                                        <li>
                                            <a class="dropdown-item text-danger"
                                                   href="#">
                                                <i class="bi bi-trash3"></i>
                                                Request delete
                                            </a>
                                        </li>
                                    </ul>
                                </div>
                            </div>

                            <div class="member-info-list">
                                <p>
                                    <span>Current belt:</span>
                                    @if (member.Belt != null)
                                    {
                                        @member.Belt.BeltName
                                    }
                                    else
                                    {
                                        <text>Not assigned</text>
                                    }
                                </p>

                                <p>
                                    <span>Membership:</span>
                                    Beginner Plan
                                </p>

                                <p>
                                    <span>Last class attended:</span>
                                    18 June 2026
                                </p>

                                <p>
                                    <span>Outstanding payment:</span>
                                    $0
                                </p>
                            </div>

                            <a class="manage-member-link"
                                   asp-controller="Members"
                                   asp-action="Details"
                                   asp-route-id="@member.MemberId">
                                Manage Member
                                <i class="bi bi-chevron-right"></i>
                            </a>
                        </div>
                    }
                </div>

                <button class="carousel-arrow right-arrow" type="button" onclick="scrollMembers(1)">
                    <i class="bi bi-chevron-right"></i>
                </button>
            </div>
        }
        else
        {
            <div class="no-member-card">
                <h2>No members added yet</h2>
            </div>
        }
    </section>
}

@section Scripts {
    <script>
        function scrollMembers(direction) {
            const carousel = document.getElementById("memberCarousel");
            const card = carousel.querySelector(".member-card-box");

            if (!card) {
                return;
            }

            const scrollAmount = card.offsetWidth + 18;

            carousel.scrollBy({
                left: direction * scrollAmount,
                behavior: "smooth"
            });
        }
    </script>
}