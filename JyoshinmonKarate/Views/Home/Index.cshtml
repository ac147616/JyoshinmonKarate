@{
    ViewData["Title"] = "Home";
}

<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/swiper@11/swiper-bundle.min.css" />

<style>
    .guest-hero {
        text-align: center;
        padding: 70px 0 40px;
        overflow: hidden;
    }

    .guest-hero h1 {
        color: #111;
        font-size: 4rem;
        font-weight: 800;
        line-height: 1.05;
        margin-bottom: 20px;
    }

    .guest-hero p {
        color: #373544;
        max-width: 650px;
        margin: 0 auto 30px;
        font-size: 1.1rem;
        line-height: 1.6;
    }

    .hero-buttons {
        margin-bottom: 25px;
    }

    .hero-buttons a {
        display: inline-block;
        padding: 12px 28px;
        margin: 0 8px;
        border-radius: 999px;
        font-weight: 600;
        text-decoration: none;
    }

    .primary-btn {
        background-color: #d71920;
        color: white;
    }

    .secondary-btn {
        background-color: white;
        color: #373544;
        border: 1px solid #ddd;
    }
    
    .hero-gallery-carousel {
        width: 100vw;
        margin-left: calc(50% - 50vw);
        padding: 35px 0 60px;
        overflow: hidden;
        perspective: 1200px;
    }

        .hero-gallery-carousel .swiper-wrapper {
            align-items: center;
            transition-timing-function: linear !important;
        }

        .hero-gallery-carousel .swiper-slide {
            width: 165px !important;
            height: 245px !important;
            display: flex;
            justify-content: center;
            align-items: center;
        }

        .hero-gallery-carousel img {
            width: 165px;
            height: 245px;
            object-fit: cover;
            border-radius: 24px;
            display: block;
            box-shadow: none;
            transition: transform 0.25s ease, opacity 0.25s ease;
            transform-style: preserve-3d;
        }
</style>

@if (User.Identity?.IsAuthenticated != true)
{
    <section class="guest-hero">
        <h1>
            Manage Your Karate<br />
            Journey in One Place
        </h1>

        <p>
            A simple online portal for members, parents, instructors, and administrators
            to view schedules, attendance, grading progress, memberships, and payments.
        </p>

        <div class="hero-buttons">
            <a class="primary-btn" asp-area="Identity" asp-page="/Account/Register">
                Register
            </a>

            <a class="secondary-btn" asp-area="Identity" asp-page="/Account/Login">
                Login
            </a>
        </div>

        <div class="swiper hero-gallery-carousel">
            <div class="swiper-wrapper">
                @for (int repeat = 0; repeat < 4; repeat++)
                {
                    for (int i = 1; i <= 10; i++)
                    {
                        <div class="swiper-slide">
                            <img src="~/images/carousel@(i).jpg" alt="Karate Image">
                        </div>
                    }
                }
            </div>
        </div>
    </section>
}

<script src="https://cdn.jsdelivr.net/npm/swiper@11/swiper-bundle.min.js"></script>
<script>
    window.addEventListener("load", function () {
    const gallerySwiper = new Swiper(".hero-gallery-carousel", {
    slidesPerView: "auto",
    centeredSlides: true,
    loop: true,
    loopAdditionalSlides: 20,
    spaceBetween: 15,
    grabCursor: true,
    speed: 1200,
    watchSlidesProgress: true,

    autoplay: {
    delay: 1800,
    disableOnInteraction: false
    },

    on: {
    setTranslate: function () {
    updateGalleryDepth(this);
    },
    slideChange: function () {
    updateGalleryDepth(this);
    }
    }
    });

    updateGalleryDepth(gallerySwiper);
    gallerySwiper.update();
    gallerySwiper.slideNext(0);
    gallerySwiper.autoplay.start();
    
    });

    function updateGalleryDepth(swiper) {
    swiper.slides.forEach(function (slide) {
    const img = slide.querySelector("img");
    if (!img) return;

    const progress = slide.progress;
    const absProgress = Math.abs(progress);

    const rotateY = progress * 10;
    const scale = 1 + Math.min(absProgress * 0.03, 0.10);

    img.style.transform =
    "perspective(900px) " +
    "rotateY(" + rotateY + "deg) " +
    "scale(" + scale + ")";
    });
    }
</script>