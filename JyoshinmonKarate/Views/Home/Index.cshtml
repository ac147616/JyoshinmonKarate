@model List<JyoshinmonKarate.Models.Member>

@{
    ViewData["Title"] = "Home";

    var carouselImages = new[]
    {
        "carousel1.jpg",
        "carousel2.jpg",
        "carousel3.jpg",
        "carousel4.jpg",
        "carousel5.jpg",
        "carousel6.jpg",
        "carousel7.jpg",
        "carousel8.jpg",
        "carousel9.jpg",
        "carousel10.jpg"
    };
}

@section Styles {
    <link rel="stylesheet" href="~/css/home.css" asp-append-version="true" />
}

@if (User.Identity?.IsAuthenticated != true)
{
    <section class="guest-hero">
        <h1>
            Manage Your Karate<br />
            Journey in One Place
        </h1>

        <p>
            Welcome to Jyoshinmon Karate's online portal for members and instructors to view attendance, manage payments, and track progress!
        </p>

        <div class="hero-buttons">
            <a class="primary-btn" asp-area="Identity" asp-page="/Account/Register">Register</a>
            <a class="secondary-btn" asp-area="Identity" asp-page="/Account/Login">Login</a>
        </div>

        <div class="scene">
            <div class="a3d" style="--n:@(carouselImages.Length * 2)">

                @for (int repeat = 0; repeat < 2; repeat++)
                {
                    for (int i = 0; i < carouselImages.Length; i++)
                    {
                        <img class="card" src="~/images/@carouselImages[i]" style="--i:@(repeat* carouselImages.Length + i)" alt="Karate Image" />
                    }
                }

            </div>
        </div>
    </section>
}

@if (User.Identity != null && User.Identity.IsAuthenticated && User.IsInRole("User"))
{
    <section class="member-home">

        <div class="member-home-top">
            <div>
                <h1>My Members</h1>
                <p>Select a member to manage their profile, attendance, payments, progress and more.</p>
            </div>

            <a class="add-member-btn" asp-controller="Members" asp-action="Create">
                <i class="bi bi-person-plus"></i>
                Add Member
            </a>
        </div>

        @if (Model != null && Model.Count > 0)
        {
            <div class="member-carousel-wrap">

                <button class="carousel-arrow left-arrow" type="button" onclick="scrollMembers(-1)">
                    <i class="bi bi-chevron-left"></i>
                </button>

                <div class="member-carousel" id="memberCarousel">

                    @{
                        var membershipNames = ViewBag.MembershipNames as Dictionary<int, string>;
                        var lastClassDates = ViewBag.LastClassDates as Dictionary<int, string>;
                        var outstandingPayments = ViewBag.OutstandingPayments as Dictionary<int, decimal>;
                    }

                    @foreach (var member in Model)
                    {
                        string membershipName = "Not assigned";
                        string lastClassAttended = "No attendance yet";
                        decimal outstandingPayment = 0;

                        if (membershipNames != null && membershipNames.ContainsKey(member.MemberId))
                        {
                            membershipName = membershipNames[member.MemberId];
                        }

                        if (lastClassDates != null && lastClassDates.ContainsKey(member.MemberId))
                        {
                            lastClassAttended = lastClassDates[member.MemberId];
                        }

                        if (outstandingPayments != null && outstandingPayments.ContainsKey(member.MemberId))
                        {
                            outstandingPayment = outstandingPayments[member.MemberId];
                        }

                        string paymentClass = "payment-clear";

                        if (outstandingPayment > 0)
                        {
                            paymentClass = "payment-due";
                        }

                        <div class="member-card-box">

                            <div class="member-avatar">
                                @if (!string.IsNullOrEmpty(member.ProfilePhotoPath))
                                {
                                    <img src="@member.ProfilePhotoPath" alt="@member.FirstName" />
                                }
                                else
                                {
                                    <i class="bi bi-person-fill"></i>
                                }
                            </div>

                            <div class="member-name-row">
                                <h2>@member.FirstName @member.LastName</h2>

                                <div class="dropdown">
                                    <button class="member-menu-btn" type="button" data-bs-toggle="dropdown" aria-expanded="false">
                                        <i class="bi bi-three-dots-vertical"></i>
                                    </button>

                                    <ul class="dropdown-menu dropdown-menu-end member-dropdown-menu">
                                        <li>
                                            <a class="dropdown-item" asp-controller="Members" asp-action="Edit" asp-route-id="@member.MemberId">
                                                <i class="bi bi-pencil-square"></i>
                                                Edit member
                                            </a>
                                        </li>

                                        <li>
                                            <a class="dropdown-item text-danger" href="#">
                                                <i class="bi bi-trash3"></i>
                                                Request delete
                                            </a>
                                        </li>
                                    </ul>
                                </div>
                            </div>

                            <div class="member-info-list">
                                <p>
                                    <span>Current belt:</span>

                                    @if (member.Belt != null)
                                    {
                                        @member.Belt.BeltName
                                    }
                                    else
                                    {
                                        <text>Not assigned</text>
                                    }
                                </p>

                                <p>
                                    <span>Membership:</span>
                                    @membershipName
                                </p>

                                <p>
                                    <span>Last class attended:</span>
                                    @lastClassAttended
                                </p>

                                <p>
                                    <span>Outstanding payment:</span>
                                    <span class="@paymentClass">$@outstandingPayment</span>
                                </p>
                            </div>

                            <a class="manage-member-link" asp-controller="Members" asp-action="Details" asp-route-id="@member.MemberId">
                                Manage Member
                                <i class="bi bi-chevron-right"></i>
                            </a>

                        </div>
                    }

                </div>

                <button class="carousel-arrow right-arrow" type="button" onclick="scrollMembers(1)">
                    <i class="bi bi-chevron-right"></i>
                </button>

            </div>
        }
        else
        {
            <div class="no-member-card">
                <h2>No members added yet</h2>
            </div>
        }

    </section>
}

@if (User.Identity != null && User.Identity.IsAuthenticated && User.IsInRole("Admin"))
{
    int totalMembers = ViewBag.TotalMembers ?? 0;
    int totalInstructors = ViewBag.TotalInstructors ?? 0;
    int totalDojos = ViewBag.TotalDojos ?? 0;
    int activeMemberships = ViewBag.ActiveMemberships ?? 0;
    int pendingPayments = ViewBag.PendingPayments ?? 0;
    int failedPayments = ViewBag.FailedPayments ?? 0;
    int upcomingGradings = ViewBag.UpcomingGradings ?? 0;

    decimal outstandingPaymentTotal = 0;

    if (ViewBag.OutstandingPaymentTotal != null)
    {
        outstandingPaymentTotal = Convert.ToDecimal(ViewBag.OutstandingPaymentTotal);
    }

    var recentMembers = ViewBag.RecentMembers as List<JyoshinmonKarate.Models.Member>;

    <section class="admin-dashboard-page">

        <div class="admin-dashboard-header">
            <div>
                <h1>Admin Dashboard</h1>
                <p>Manage members, classes, payments, memberships and grading activity.</p>
            </div>

            <a asp-controller="Members" asp-action="Create" class="admin-primary-btn">
                <i class="bi bi-person-plus"></i>
                Add Member
            </a>
        </div>

        <div class="admin-summary-grid">

            <a asp-controller="Members" asp-action="Index" class="admin-summary-card">
                <div class="admin-summary-icon">
                    <i class="bi bi-people"></i>
                </div>

                <div>
                    <p>Total Members</p>
                    <h2>@totalMembers</h2>
                </div>
            </a>

            <a asp-controller="Instructors" asp-action="Index" class="admin-summary-card">
                <div class="admin-summary-icon">
                    <i class="bi bi-person-badge"></i>
                </div>

                <div>
                    <p>Instructors</p>
                    <h2>@totalInstructors</h2>
                </div>
            </a>

            <a asp-controller="Clubs" asp-action="Index" class="admin-summary-card">
                <div class="admin-summary-icon">
                    <i class="bi bi-building"></i>
                </div>

                <div>
                    <p>Dojos</p>
                    <h2>@totalDojos</h2>
                </div>
            </a>

            <a asp-controller="MemberMemberships" asp-action="Index" asp-route-membershipStatus="Active" class="admin-summary-card">
                <div class="admin-summary-icon">
                    <i class="bi bi-card-checklist"></i>
                </div>

                <div>
                    <p>Active Memberships</p>
                    <h2>@activeMemberships</h2>
                </div>
            </a>

        </div>

        <div class="admin-dashboard-main">

            <div class="admin-attention-panel">

                <div class="admin-panel-heading">
                    <div>
                        <h2>Needs Attention</h2>
                        <p>Important records that may need admin action.</p>
                    </div>
                </div>

                <div class="attention-grid">

                    <a asp-controller="Payments" asp-action="Index" asp-route-paymentStatus="Pending" class="attention-card">
                        <div class="attention-card-top">
                            <i class="bi bi-hourglass-split"></i>
                            <span>Pending Payments</span>
                        </div>

                        <h3>@pendingPayments</h3>
                        <p>Payments waiting to be completed.</p>
                    </a>

                    <a asp-controller="Payments" asp-action="Index" asp-route-paymentStatus="Failed" class="attention-card attention-danger">
                        <div class="attention-card-top">
                            <i class="bi bi-exclamation-circle"></i>
                            <span>Failed Payments</span>
                        </div>

                        <h3>@failedPayments</h3>
                        <p>Payments that were not successful.</p>
                    </a>

                    <a asp-controller="Payments" asp-action="Index" class="attention-card">
                        <div class="attention-card-top">
                            <i class="bi bi-cash-stack"></i>
                            <span>Outstanding Total</span>
                        </div>

                        <h3>$@outstandingPaymentTotal.ToString("0.00")</h3>
                        <p>Total pending and failed payment amount.</p>
                    </a>

                    <a asp-controller="Gradings" asp-action="Index" class="attention-card">
                        <div class="attention-card-top">
                            <i class="bi bi-calendar-event"></i>
                            <span>Upcoming Gradings</span>
                        </div>

                        <h3>@upcomingGradings</h3>
                        <p>Gradings scheduled from today onwards.</p>
                    </a>

                </div>
            </div>

            <aside class="admin-quick-actions-panel">

                <div class="admin-panel-heading">
                    <div>
                        <h2>Quick Actions</h2>
                        <p>Create common records.</p>
                    </div>
                </div>

                <div class="admin-quick-links">

                    <a asp-controller="Attendances" asp-action="Create">
                        <i class="bi bi-calendar-check"></i>
                        Record Attendance
                    </a>

                    <a asp-controller="Payments" asp-action="Create">
                        <i class="bi bi-cash-stack"></i>
                        Add Payment
                    </a>

                    <a asp-controller="MemberMemberships" asp-action="Create">
                        <i class="bi bi-card-checklist"></i>
                        Assign Membership
                    </a>

                    <a asp-controller="MemberGradings" asp-action="Create">
                        <i class="bi bi-trophy"></i>
                        Record Grading
                    </a>

                </div>
            </aside>

        </div>

        <div class="admin-management-panel">

            <div class="admin-panel-heading">
                <div>
                    <h2>Manage Karate Portal</h2>
                    <p>Open an area to view and manage its records.</p>
                </div>
            </div>

            <div class="admin-management-grid">

                <a asp-controller="Members" asp-action="Index" class="admin-management-link">
                    <i class="bi bi-people"></i>
                    <span>Members</span>
                </a>

                <a asp-controller="Attendances" asp-action="Index" class="admin-management-link">
                    <i class="bi bi-calendar-check"></i>
                    <span>Attendance</span>
                </a>

                <a asp-controller="Payments" asp-action="Index" class="admin-management-link">
                    <i class="bi bi-cash-stack"></i>
                    <span>Payments</span>
                </a>

                <a asp-controller="MemberMemberships" asp-action="Index" class="admin-management-link">
                    <i class="bi bi-card-checklist"></i>
                    <span>Member Memberships</span>
                </a>

                <a asp-controller="Gradings" asp-action="Index" class="admin-management-link">
                    <i class="bi bi-calendar-event"></i>
                    <span>Gradings</span>
                </a>

                <a asp-controller="MemberGradings" asp-action="Index" class="admin-management-link">
                    <i class="bi bi-trophy"></i>
                    <span>Member Gradings</span>
                </a>

                <a asp-controller="Schedules" asp-action="Index" class="admin-management-link">
                    <i class="bi bi-calendar3"></i>
                    <span>Schedules</span>
                </a>

                <a asp-controller="Instructors" asp-action="Index" class="admin-management-link">
                    <i class="bi bi-person-badge"></i>
                    <span>Instructors</span>
                </a>

                <a asp-controller="Clubs" asp-action="Index" class="admin-management-link">
                    <i class="bi bi-building"></i>
                    <span>Dojos</span>
                </a>

                <a asp-controller="Belts" asp-action="Index" class="admin-management-link">
                    <i class="bi bi-award"></i>
                    <span>Belts</span>
                </a>

                <a asp-controller="Memberships" asp-action="Index" class="admin-management-link">
                    <i class="bi bi-tags"></i>
                    <span>Membership Plans</span>
                </a>

            </div>
        </div>

        <div class="admin-recent-panel">

            <div class="admin-panel-heading recent-heading">
                <div>
                    <h2>Recently Added Members</h2>
                    <p>The latest members added to the portal.</p>
                </div>

                <a asp-controller="Members" asp-action="Index" class="view-all-link">
                    View all
                    <i class="bi bi-chevron-right"></i>
                </a>
            </div>

            @if (recentMembers != null && recentMembers.Count > 0)
            {
                <div class="admin-recent-table-wrap">
                    <table class="admin-recent-table">
                        <thead>
                            <tr>
                                <th>Member</th>
                                <th>Dojo</th>
                                <th>Belt</th>
                                <th>Date Joined</th>
                                <th></th>
                            </tr>
                        </thead>

                        <tbody>
                            @foreach (var member in recentMembers)
                            {
                                string dojoName = "Not assigned";
                                string beltName = "Not assigned";

                                if (member.Club != null)
                                {
                                    dojoName = member.Club.ClubName;
                                }

                                if (member.Belt != null)
                                {
                                    beltName = member.Belt.BeltName;
                                }

                                <tr>
                                    <td>
                                        <strong>@member.FirstName @member.LastName</strong>
                                    </td>

                                    <td>@dojoName</td>
                                    <td>@beltName</td>
                                    <td>@member.DateJoined.ToString("dd MMM yyyy")</td>

                                    <td>
                                        <a asp-controller="Members" asp-action="Details" asp-route-id="@member.MemberId">View</a>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            }
            else
            {
                <p class="admin-empty-message">No members have been added yet.</p>
            }

        </div>

    </section>
}

@section Scripts {
    <script>
        function scrollMembers(direction) {
            const carousel = document.getElementById("memberCarousel");
            const card = carousel.querySelector(".member-card-box");

            if (!card) {
                return;
            }

            const scrollAmount = card.offsetWidth + 18;

            carousel.scrollBy({
                left: direction * scrollAmount,
                behavior: "smooth"
            });
        }
    </script>
}