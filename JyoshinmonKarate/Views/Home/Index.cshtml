@{
    ViewData["Title"] = "Home Page";
}

<style>
    .guest-hero {
        min-height: 650px;
        padding: 70px 20px 40px;
        text-align: center;
        overflow: hidden;
    }

    .hero-badge {
        display: inline-block;
        padding: 8px 18px;
        margin-bottom: 25px;
        background-color: #ffe1a6;
        color: #373544;
        font-weight: 600;
        border-radius: 999px;
        font-size: 0.95rem;
    }

    .guest-hero h1 {
        color: #111111;
        font-size: 4rem;
        font-weight: 800;
        line-height: 1.05;
        margin-bottom: 22px;
    }

    .guest-hero p {
        color: #373544;
        font-size: 1.15rem;
        max-width: 650px;
        margin: 0 auto 35px;
        line-height: 1.6;
    }

    .hero-buttons {
        margin-bottom: 45px;
    }

        .hero-buttons a {
            display: inline-block;
            text-decoration: none;
            padding: 12px 26px;
            margin: 0 8px;
            border-radius: 999px;
            font-weight: 600;
        }

    .primary-btn {
        background-color: #d71920;
        color: white;
        box-shadow: 0 8px 18px rgba(215, 25, 32, 0.25);
    }

    .secondary-btn {
        background-color: white;
        color: #373544;
        border: 1px solid #ddd;
    }

    .hero-gallery {
        display: flex;
        justify-content: center;
        align-items: center;
        gap: 22px;
        margin-top: 20px;
    }

        .hero-gallery img {
            width: 160px;
            height: 260px;
            object-fit: cover;
            border-radius: 24px;
            box-shadow: 0 14px 28px rgba(0, 0, 0, 0.20);
            transition: transform 0.25s ease;
        }

            .hero-gallery img:nth-child(1) {
                transform: rotate(-7deg) translateY(10px);
            }

            .hero-gallery img:nth-child(2) {
                transform: rotate(4deg) translateY(-5px);
            }

            .hero-gallery img:nth-child(3) {
                transform: rotate(-3deg) translateY(8px);
            }

            .hero-gallery img:nth-child(4) {
                transform: rotate(3deg) translateY(-8px);
            }

            .hero-gallery img:nth-child(5) {
                transform: rotate(-4deg) translateY(6px);
            }

            .hero-gallery img:nth-child(6) {
                transform: rotate(6deg) translateY(-4px);
            }

            .hero-gallery img:hover {
                transform: translateY(-14px) scale(1.04);
            }

    @@media (max-width: 768px) {
        .guest-hero h1 {
            font-size: 2.5rem;
        }

        .hero-gallery {
            overflow-x: auto;
            justify-content: flex-start;
            padding-bottom: 20px;
        }

            .hero-gallery img {
                width: 140px;
                height: 220px;
                flex-shrink: 0;
            }
    }
</style>

@if (User.Identity?.IsAuthenticated != true)
{
    <section class="guest-hero">
        <h1>
            Manage Your Karate<br />
            Journey in One Place
        </h1>

        <p>
            A simple online portal for members, parents, instructors, and administrators
            to view schedules, attendance, grading progress, memberships, and payments.
        </p>

        <div class="hero-buttons">
            <a class="primary-btn" asp-area="Identity" asp-page="/Account/Register">
                Register
            </a>

            <a class="secondary-btn" asp-area="Identity" asp-page="/Account/Login">
                Login
            </a>
        </div>

        <div class="hero-gallery">
            @for (int i = 1; i <= 6; i++)
            {
                <img src="~/images/carousel@(i).jpg" alt="Karate training photo" />
            }
        </div>
    </section>
}