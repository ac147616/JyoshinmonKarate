@{
    ViewData["Title"] = "Home Page";
}

<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/swiper@11/swiper-bundle.min.css" />

<style>
    .welcome-swiper {
        width: 100%;
        height: 330px;
        padding: 20px 0 45px 0;
    }

    .welcome-swiper .swiper-slide {
        width: 75%;
        background: white;
        box-shadow: 0 10px 25px rgba(0, 0, 0, 0.25);
        overflow: hidden;
    }

    .welcome-swiper .swiper-slide img {
        width: 100%;
        height: 300px;
        object-fit: cover;
        display: block;
    }

    .welcome-swiper .swiper-button-prev,
    .welcome-swiper .swiper-button-next {
        color: #d71920;
    }

    .welcome-swiper .swiper-pagination-bullet-active {
        background: #d71920;
    }
</style>

@if (!User.Identity.IsAuthenticated){
    <div class="row mt-5">
        <div class="col-md-6">            
            <div class="swiper welcome-swiper">
                <div class="swiper-wrapper">
                    @for (int i = 1; i <= 10; i++)
                    {
                        <div class="swiper-slide">
                            <img src="~/images/carousel@(i).jpg" alt="Karate image" />
                        </div>
                    }
                </div>

                <div class="swiper-button-prev"></div>
                <div class="swiper-button-next"></div>
                <div class="swiper-pagination"></div>
            </div>
        </div>
        <div class="col-md-6 d-flex flex-column justify-content-center">
            <h1 style="color: #373544;">Jyoshinmon Karate</h1>
            <p style="color: #373544;">Welcome to the Jyoshinmon Karate Club management system.</p>
            <p style="color: #373544;">
                Our club has been training members across Auckland for many years,
                offering classes for all ages and skill levels from White Belt through to Black Belt.
            </p>
            <p style="color: #373544;">
                Use the navigation above to manage members, schedules,
                gradings, and more.
            </p>
        </div>
    </div>
}
<script src="https://cdn.jsdelivr.net/npm/swiper@11/swiper-bundle.min.js"></script>
<script>
    const swiper = new Swiper(".welcome-swiper", {
        effect: "coverflow",
        grabCursor: true,
        centeredSlides: true,
        slidesPerView: "auto",
        loop: true,

        coverflowEffect: {
            rotate: 0,
            stretch: 40,
            depth: 150,
            modifier: 1.5,
            slideShadows: true
        },

        autoplay: {
            delay: 3000,
            disableOnInteraction: false
        },

        navigation: {
            nextEl: ".swiper-button-next",
            prevEl: ".swiper-button-prev"
        },

        pagination: {
            el: ".swiper-pagination",
            clickable: true
        }
    });
</script>
