@model JyoshinmonKarate.Models.Instructor

@{
    ViewData["Title"] = "Create Instructor";
}

@section Styles {
    <link rel="stylesheet" href="~/css/instructor.css" asp-append-version="true" />
}

<section class="instructor-form-page">
    <div class="instructor-form-card">

        <div class="instructor-form-header">
            <h1>Create Instructor</h1>
        </div>

        <form asp-action="Create" method="post">
            <div asp-validation-summary="All" class="text-danger"></div>

            <div class="instructor-form-row">

                <div class="instructor-form-group">
                    <label asp-for="UserId">User Account</label>
                    <select asp-for="UserId" class="instructor-form-control" asp-items="ViewBag.UserId">
                        <option value="">Select a user</option>
                    </select>
                    <span asp-validation-for="UserId" class="instructor-field-error"></span>
                </div>

                <div class="instructor-form-group">
                    <label asp-for="ClubId">Club</label>
                    <select asp-for="ClubId" class="instructor-form-control" asp-items="ViewBag.ClubId">
                        <option value="">Select a club</option>
                    </select>
                    <span asp-validation-for="ClubId" class="instructor-field-error"></span>
                </div>

                <div class="instructor-form-group">
                    <label asp-for="BeltId">Belt</label>
                    <select asp-for="BeltId" class="instructor-form-control" asp-items="ViewBag.BeltId">
                        <option value="">Select a belt</option>
                    </select>
                    <span asp-validation-for="BeltId" class="instructor-field-error"></span>
                </div>

                <div class="instructor-form-group">
                    <label asp-for="DateJoined">Date Joined</label>
                    <input asp-for="DateJoined" class="instructor-form-control" />
                    <span asp-validation-for="DateJoined" class="instructor-field-error"></span>
                </div>

            </div>

            <div class="instructor-form-actions">
                <button type="submit" class="instructor-primary-btn">Create Instructor</button>
                <a asp-action="Index" class="instructor-cancel-link">Cancel</a>
            </div>
        </form>

    </div>
</section>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}
```
