@model JyoshinmonKarate.Models.Instructor

@{
    ViewData["Title"] = "Instructor Details";

    string instructorName = Model.User.FirstName + " " + Model.User.LastName;
}

@section Styles {
    <link rel="stylesheet" href="~/css/instructor.css" asp-append-version="true" />
}

<section class="instructor-form-page">
    <div class="instructor-form-card">

        <div class="instructor-form-header">
            <h1>Instructor Info</h1>
        </div>

        <div class="details-grid">

            <div class="details-item">
                <span>Instructor name</span>
                <p>@instructorName</p>
            </div>

            <div class="details-item">
                <span>User account</span>
                <p>@Model.User.Email</p>
            </div>

            <div class="details-item">
                <span>Club</span>
                <p>@Model.Club.ClubName</p>
            </div>

            <div class="details-item">
                <span>Current belt</span>
                <p>@Model.Belt.BeltName</p>
            </div>

            <div class="details-item">
                <span>Date joined</span>
                <p>@Model.DateJoined.ToString("dd MMM yyyy")</p>
            </div>

        </div>

        <div class="form-actions">
            <a asp-action="Edit" asp-route-id="@Model.InstructorId" class="instructor-primary-btn">Edit Instructor</a>
            <a asp-action="Index" class="cancel-link">Back to List</a>
        </div>

    </div>
</section>
