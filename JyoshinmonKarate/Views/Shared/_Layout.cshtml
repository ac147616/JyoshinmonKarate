<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - JyoshinmonKarate</title>
    <script type="importmap"></script>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/JyoshinmonKarate.styles.css" asp-append-version="true" />
    <style>
        body {
            background-color: #C5C8CB;
        }
        .navbar .nav-link,
        .navbar .navbar-brand,
        .dropdown-toggle {
            color: white !important;
        }

    </style>
</head>
<body>
    <header>
        <nav class="navbar navbar-expand-sm navbar-toggleable-sm navbar-dark border-bottom box-shadow mb-3">
            <div class="container-fluid">
                <a class="navbar-brand" asp-area="" asp-controller="Home" asp-action="Index"> 
                    <img src="~/images/logo.png" alt="Jyoshinmon Karate"
                         style="height: 125px; margin-top: -60px; margin-bottom: -60px; margin-left: 30px; " />
                </a>
                <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target=".navbar-collapse" aria-controls="navbarSupportedContent"
                        aria-expanded="false" aria-label="Toggle navigation">
                    <span class="navbar-toggler-icon"></span>
                </button>
                <div class="navbar-collapse collapse d-sm-inline-flex justify-content-between">
                    <ul class="navbar-nav flex-grow-1">
                        @if (User.IsInRole("User") || User.IsInRole("Admin"))
                            {
                            <li class="nav-item dropdown">
                                <a class="nav-link dropdown-toggle" href="#" id="memberDropdown" role="button" data-bs-toggle="dropdown" aria-expanded="false">
                                    Club Member Functions
                                </a>
                                <ul class="dropdown-menu" aria-labelledby="memberDropdown">
                                    <li><a class="dropdown-item" asp-area="" asp-controller="Attendances" asp-action="Index">Attendance</a></li>
                                    <li><a class="dropdown-item" asp-area="" asp-controller="Schedules" asp-action="Index">Schedules</a></li>
                                    <li><a class="dropdown-item" asp-area="" asp-controller="Payments" asp-action="Index">Payments</a></li>
                                    <li><a class="dropdown-item" asp-area="" asp-controller="MemberGradings" asp-action="Index">Member Gradings</a></li>
                                    <li><a class="dropdown-item" asp-area="" asp-controller="Members" asp-action="Index">Members</a></li>
                                    <li><a class="dropdown-item" asp-area="" asp-controller="MemberMemberships" asp-action="Index">Member Membership</a></li>
                                </ul>
                            </li>
                            }

                        @if (User.IsInRole("Admin")){
                        <li class="nav-item dropdown">
                            <a class="nav-link dropdown-toggle" href="#" id="adminDropdown" role="button" data-bs-toggle="dropdown" aria-expanded="false">
                                Admin Functions
                            </a>
                            <ul class="dropdown-menu" aria-labelledby="adminDropdown">
                                <li><a class="dropdown-item" asp-area="" asp-controller="Belts" asp-action="Index">Belts</a></li>
                                <li><a class="dropdown-item" asp-area="" asp-controller="Clubs" asp-action="Index">Clubs</a></li>
                                <li><a class="dropdown-item" asp-area="" asp-controller="Memberships" asp-action="Index">Memberships</a></li>
                                <li><a class="dropdown-item" asp-area="" asp-controller="Instructors" asp-action="Index">Instructors</a></li>
                                <li><a class="dropdown-item" asp-area="" asp-controller="Gradings" asp-action="Index">Gradings</a></li>
                            </ul>
                        </li>
                        }
                    </ul>
                    <partial name = "_LoginPartial"/>
                </div>
            </div>
        </>
    </header>

    <div id="welcomePageCarousel" class="carousel slide" data-bs-ride="carousel" data-bs-interval="3000">
        <div class="carousel-inner">
            <div class="carousel-item active">
                <img src="/images/carousel1.jpg" class="d-block w-100" alt="...">
            </div>
            <div class="carousel-item">
                <img src="/images/carousel2.jpg" class="d-block w-100" alt="...">
            </div>
            <div class="carousel-item">
                <img src="/images/carousel3.jpg" class="d-block w-100" alt="...">
            </div>
            <div class="carousel-item">
                <img src="/images/carousel4.jpg" class="d-block w-100" alt="...">
            </div>
            <div class="carousel-item">
                <img src="/images/carousel5.jpg" class="d-block w-100" alt="...">
            </div>
            <div class="carousel-item">
                <img src="/images/carousel6.jpg" class="d-block w-100" alt="...">
            </div>
            <div class="carousel-item">
                <img src="/images/carousel7.jpg" class="d-block w-100" alt="...">
            </div>
            <div class="carousel-item">
                <img src="/images/carousel8.jpg" class="d-block w-100" alt="...">
            </div>
            <div class="carousel-item">
                <img src="/images/carousel9.jpg" class="d-block w-100" alt="...">
            </div>
            <div class="carousel-item">
                <img src="/images/carousel10.jpg" class="d-block w-100" alt="...">
            </div>
        </div>
        <button class="carousel-control-prev" type="button" data-bs-target="#welcomePageCarousel" data-bs-slide="prev">
            <span class="carousel-control-prev-icon" aria-hidden="true"></span>
            <span class="visually-hidden">Previous</span>
        </button>
        <button class="carousel-control-next" type="button" data-bs-target="#welcomePageCarousel" data-bs-slide="next">
            <span class="carousel-control-next-icon" aria-hidden="true"></span>
            <span class="visually-hidden">Next</span>
        </button>
    </div>

    <div class="container">
        <main role="main" class="pb-3">
            @RenderBody()
        </main>
    </div>

    <footer class="border-top footer text-muted">
    </footer>
    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
