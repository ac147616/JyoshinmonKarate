@model JyoshinmonKarate.Models.Schedule

@{
    ViewData["Title"] = "Delete Class Schedule";

    string instructorName = Model.Instructor.User.FirstName + " " + Model.Instructor.User.LastName;
}

@section Styles {
    <link rel="stylesheet" href="~/css/schedule.css" asp-append-version="true" />
}

<section class="schedule-form-page">
    <div class="schedule-form-card">

        <div class="schedule-form-header">
            <h1>Delete Class Schedule</h1>
            <p>Deleting this class schedule will permanently remove it from the system.</p>
        </div>

        <div class="details-grid">

            <div class="details-item">
                <span>Dojo</span>
                <p>@Model.Club.ClubName</p>
            </div>

            <div class="details-item">
                <span>Instructor</span>
                <p>@instructorName</p>
            </div>

            <div class="details-item">
                <span>Level</span>
                <p>@Model.Level</p>
            </div>

            <div class="details-item">
                <span>Day of week</span>
                <p>@Model.DayOfWeek</p>
            </div>

            <div class="details-item">
                <span>Start time</span>
                <p>@Model.StartTime.ToString("hh:mm tt")</p>
            </div>

            <div class="details-item">
                <span>End time</span>
                <p>@Model.EndTime.ToString("hh:mm tt")</p>
            </div>

        </div>

        <form asp-action="Delete" method="post" class="form-actions">
            <input type="hidden" asp-for="ScheduleId" />

            <button type="submit" class="delete-btn">Delete Schedule</button>
            <a asp-action="Index" class="cancel-link">Cancel</a>
        </form>

    </div>
</section>