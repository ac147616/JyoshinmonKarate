@model JyoshinmonKarate.Models.Schedule

@{
    ViewData["Title"] = "Edit Class Schedule";
}

@section Styles {
    <link rel="stylesheet" href="~/css/schedule.css" asp-append-version="true" />
}

<section class="schedule-form-page">
    <div class="schedule-form-card">

        <div class="schedule-form-header">
            <h1>Edit Class Schedule</h1>
        </div>

        <form asp-action="Edit" method="post">
            <div asp-validation-summary="ModelOnly" class="text-danger"></div>

            <input type="hidden" asp-for="ScheduleId" />

            <div class="form-grid">

                <div class="form-group">
                    <label asp-for="ClubId">Dojo</label>
                    <select asp-for="ClubId" class="form-control" asp-items="ViewBag.ClubId"></select>
                    <span asp-validation-for="ClubId" class="text-danger"></span>
                </div>

                <div class="form-group">
                    <label asp-for="InstructorId">Instructor</label>
                    <select asp-for="InstructorId" class="form-control" asp-items="ViewBag.InstructorId"></select>
                    <span asp-validation-for="InstructorId" class="text-danger"></span>
                </div>

                <div class="form-group">
                    <label asp-for="Level">Level</label>
                    <select asp-for="Level" class="form-control" asp-items="Html.GetEnumSelectList<JyoshinmonKarate.Models.Levels>()"></select>
                    <span asp-validation-for="Level" class="text-danger"></span>
                </div>

                <div class="form-group">
                    <label asp-for="DayOfWeek">Day of Week</label>
                    <select asp-for="DayOfWeek" class="form-control" asp-items="Html.GetEnumSelectList<JyoshinmonKarate.Models.Weekdays>()"></select>
                    <span asp-validation-for="DayOfWeek" class="text-danger"></span>
                </div>

                <div class="form-group">
                    <label asp-for="StartTime">Start Time</label>
                    <input asp-for="StartTime" class="form-control" />
                    <span asp-validation-for="StartTime" class="text-danger"></span>
                </div>

                <div class="form-group">
                    <label asp-for="EndTime">End Time</label>
                    <input asp-for="EndTime" class="form-control" />
                    <span asp-validation-for="EndTime" class="text-danger"></span>
                </div>

            </div>

            <div class="form-actions">
                <button type="submit" class="save-btn">Save Changes</button>
                <a asp-action="Index" class="cancel-link">Cancel</a>
            </div>
        </form>

    </div>
</section>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}
