@model JyoshinmonKarate.Models.MemberGrading

@{
    ViewData["Title"] = "Create";
}

<h1>Create</h1>

<h4>MemberGrading</h4>
<hr />
<div class="row">
    <div class="col-md-4">
        <form asp-action="Create">
            <div asp-validation-summary="ModelOnly" class="text-danger"></div>
            <div class="form-group">
                <label asp-for="GradingId" class="control-label"></label>
                <select asp-for="GradingId" class ="form-control" asp-items="ViewBag.GradingId"></select>
            </div>
            <div class="form-group">
                <label asp-for="MemberId" class="control-label"></label>
                <select asp-for="MemberId" class ="form-control" asp-items="ViewBag.MemberId"></select>
            </div>
            <div class="form-group">
                <label asp-for="BeltBeforeId" class="control-label"></label>
                <select asp-for="BeltBeforeId" class ="form-control" asp-items="ViewBag.BeltBeforeId"></select>
            </div>
            <div class="form-group">
                <label asp-for="BeltAfterId" class="control-label"></label>
                <select asp-for="BeltAfterId" class ="form-control" asp-items="ViewBag.BeltAfterId"></select>
            </div>
            <div class="form-group form-check">
                <label class="form-check-label">
                    <input class="form-check-input" asp-for="Passed" /> @Html.DisplayNameFor(model => model.Passed)
                </label>
            </div>
            <div class="form-group">
                <input type="submit" value="Create" class="btn btn-primary" />
            </div>
        </form>
    </div>
</div>

<div>
    <a asp-action="Index">Back to List</a>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
