@model JyoshinmonKarate.Models.Membership

@{
    ViewData["Title"] = "Create Membership Plan";
}

@section Styles {
    <link rel="stylesheet" href="~/css/membership-form.css" asp-append-version="true" />
}

<section class="membership-form-page">
    <div class="membership-form-card">

        <div class="membership-form-header">
            <h1>Create Membership Plan</h1>
        </div>

        <form asp-action="Create" method="post">
            <div asp-validation-summary="ModelOnly" class="text-danger"></div>

            <div class="form-grid">

                <div class="form-group">
                    <label asp-for="MembershipName">Membership Name</label>
                    <input asp-for="MembershipName" class="form-control" />
                    <span asp-validation-for="MembershipName" class="text-danger"></span>
                </div>

                <div class="form-group">
                    <label asp-for="Cost">Membership Cost ($)</label>
                    <input asp-for="Cost" class="form-control" />
                    <span asp-validation-for="Cost" class="text-danger"></span>
                </div>

                <div class="form-group">
                    <label asp-for="AgeGroup">Age Group</label>
                    <input asp-for="AgeGroup" class="form-control" />
                    <span asp-validation-for="AgeGroup" class="text-danger"></span>
                </div>

            </div>

            <div class="form-actions">
                <button type="submit" class="save-btn">Create Plan</button>
                <a asp-action="Index" class="cancel-link">Cancel</a>
            </div>
        </form>

    </div>
</section>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}