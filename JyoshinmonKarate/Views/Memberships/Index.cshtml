@model IEnumerable<JyoshinmonKarate.Models.Membership>

@{
    ViewData["Title"] = "Membership Plans";
    bool isAdmin = User.IsInRole("Admin");
}

@section Styles {
    <link rel="stylesheet" href="~/css/membership-index.css" asp-append-version="true" />
}

<section class="membership-index-page">

    <div class="membership-header-row">
        <div class="membership-header">
            <h1>Membership Plans</h1>
        </div>

        @if (isAdmin)
        {
            <a asp-action="Create" class="add-membership-btn">
                <i class="bi bi-plus-lg"></i>
                Add Membership Plan
            </a>
        }
    </div>

    <div class="membership-table-wrap">

        <table class="membership-table">
            <thead>
                <tr>
                    <th>Membership Name</th>
                    <th>Cost</th>
                    <th>Age Group</th>
                    @if (isAdmin)
                    {
                        <th class="actions-heading">Actions</th>
                    }
                </tr>
            </thead>

            <tbody>
                @foreach (var item in Model)
                {
                    <tr>
                        <td>
                            <span class="membership-name">@item.MembershipName</span>
                        </td>

                        <td>
                            $@item.Cost.ToString("0.00")
                        </td>

                        <td>
                            @item.AgeGroup
                        </td>

                        @if (isAdmin)
                        {
                            <td>
                                <div class="membership-actions">
                                    <a asp-action="Details" asp-route-id="@item.MembershipId" class="details-membership-link">Details</a>
                                    <a asp-action="Edit" asp-route-id="@item.MembershipId" class="edit-membership-link">Edit</a>
                                    <a asp-action="Delete" asp-route-id="@item.MembershipId" class="delete-membership-link">Delete</a>
                                </div>
                            </td>
                        }
                    </tr>
                }
            </tbody>
        </table>

    </div>

</section>