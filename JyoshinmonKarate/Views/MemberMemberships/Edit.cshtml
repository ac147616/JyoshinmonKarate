@model JyoshinmonKarate.Models.MemberMembership

@{
    ViewData["Title"] = "Edit Member Membership";
}

@section Styles {
    <link rel="stylesheet" href="~/css/membermembership.css" asp-append-version="true" />
}

<section class="member-membership-form-page">
    <div class="member-membership-form-card">

        <div class="member-membership-form-header">
            <h1>Edit Membership</h1>
        </div>

        <form asp-action="Edit" method="post">
            <div asp-validation-summary="ModelOnly" class="text-danger"></div>

            <input type="hidden" asp-for="MemberMembershipId" />

            <div class="form-grid">

                <div class="form-group">
                    <label asp-for="MemberId">Member</label>
                    <select asp-for="MemberId"
                            class="form-control"
                            asp-items="ViewBag.MemberId">
                    </select>
                    <span asp-validation-for="MemberId" class="text-danger"></span>
                </div>

                <div class="form-group">
                    <label asp-for="MembershipId">Membership</label>
                    <select asp-for="MembershipId"
                            class="form-control"
                            asp-items="ViewBag.MembershipId">
                    </select>
                    <span asp-validation-for="MembershipId" class="text-danger"></span>
                </div>

                <div class="form-group">
                    <label asp-for="StartDate">Start Date</label>
                    <input asp-for="StartDate" class="form-control" />
                    <span asp-validation-for="StartDate" class="text-danger"></span>
                </div>

                <div class="form-group">
                    <label asp-for="EndDate">End Date</label>
                    <input asp-for="EndDate" class="form-control" />
                    <span asp-validation-for="EndDate" class="text-danger"></span>
                </div>

                <div class="form-group">
                    <label asp-for="MembershipStatus">Membership Status</label>
                    <select asp-for="MembershipStatus"
                            class="form-control"
                            asp-items="Html.GetEnumSelectList<JyoshinmonKarate.Models.MembershipStatus>()">
                    </select>
                    <span asp-validation-for="MembershipStatus" class="text-danger"></span>
                </div>

            </div>

            <div class="form-actions">
                <button type="submit" class="save-btn">Save Changes</button>
                <a asp-action="Index" class="cancel-link">Cancel</a>
            </div>
        </form>

    </div>
</section>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}