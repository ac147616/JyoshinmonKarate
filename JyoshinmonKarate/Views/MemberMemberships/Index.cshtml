@model IEnumerable<JyoshinmonKarate.Models.MemberMembership>

@{
    ViewData["Title"] = "Index";
}

<h1>Index</h1>

<p>
    <a asp-action="Create">Create New</a>
</p>
<table class="table">
    <thead>
        <tr>
            <th>
                @Html.DisplayNameFor(model => model.StartDate)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.EndDate)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.MembershipStatus)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.Member)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.Membership)
            </th>
            <th></th>
        </tr>
    </thead>
    <tbody>
@foreach (var item in Model) {
        <tr>
            <td>
                @Html.DisplayFor(modelItem => item.StartDate)
            </td>
            <td>
                @Html.DisplayFor(modelItem => item.EndDate)
            </td>
            <td>
                @Html.DisplayFor(modelItem => item.MembershipStatus)
            </td>
            <td>
                @Html.DisplayFor(modelItem => item.Member.EmergencyContactName)
            </td>
            <td>
                @Html.DisplayFor(modelItem => item.Membership.AgeGroup)
            </td>
            <td>
                <a asp-action="Edit" asp-route-id="@item.MemberMembershipId">Edit</a> |
                <a asp-action="Details" asp-route-id="@item.MemberMembershipId">Details</a> |
                <a asp-action="Delete" asp-route-id="@item.MemberMembershipId">Delete</a>
            </td>
        </tr>
}
    </tbody>
</table>
