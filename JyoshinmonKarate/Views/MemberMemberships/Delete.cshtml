@model JyoshinmonKarate.Models.MemberMembership

@{
    ViewData["Title"] = "Delete Member Membership";

    string memberName = Model.Member.FirstName + " " + Model.Member.LastName;
}

@section Styles {
    <link rel="stylesheet" href="~/css/membermembership.css" asp-append-version="true" />
}

<section class="member-membership-form-page">
    <div class="member-membership-form-card">

        <div class="member-membership-form-header">
            <h1>Delete Membership</h1>
            <p class="delete-warning">
                Are you sure you want to delete this member membership?
            </p>
        </div>

        <div class="details-grid">

            <div class="details-item">
                <span>Member</span>
                <p>@memberName</p>
            </div>

            <div class="details-item">
                <span>Membership</span>
                <p>@Model.Membership.MembershipName</p>
            </div>

            <div class="details-item">
                <span>Start Date</span>
                <p>@Model.StartDate.ToString("dd MMM yyyy")</p>
            </div>

            <div class="details-item">
                <span>End Date</span>
                <p>@Model.EndDate.ToString("dd MMM yyyy")</p>
            </div>

            <div class="details-item">
                <span>Membership Status</span>
                <p>@Model.MembershipStatus</p>
            </div>

        </div>

        <form asp-action="Delete" method="post">
            <input type="hidden" asp-for="MemberMembershipId" />

            <div class="form-actions">
                <button type="submit" class="delete-btn">
                    Delete Membership
                </button>

                <a asp-action="Index" class="cancel-link">
                    Cancel
                </a>
            </div>
        </form>

    </div>
</section>