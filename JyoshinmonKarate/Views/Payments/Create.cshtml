@model JyoshinmonKarate.Models.Payment

@{
    ViewData["Title"] = "Create Payment";
}

@section Styles {
    <link rel="stylesheet" href="~/css/payment.css" asp-append-version="true" />
}

<section class="payment-form-page">
    <div class="payment-form-card">

        <div class="payment-form-header">
            <h1>Create Payment</h1>
        </div>

        <form asp-action="Create" method="post">
            <div asp-validation-summary="ModelOnly" class="text-danger"></div>

            <div class="form-grid">

                <div class="form-group">
                    <label asp-for="MemberId">Member</label>
                    <select asp-for="MemberId" class="form-control" asp-items="ViewBag.MemberId">
                        <option value="">Select a member</option>
                    </select>
                    <span asp-validation-for="MemberId" class="text-danger"></span>
                </div>

                <div class="form-group">
                    <label asp-for="PaymentName">Payment Name</label>
                    <input asp-for="PaymentName" class="form-control" />
                    <span asp-validation-for="PaymentName" class="text-danger"></span>
                </div>

                <div class="form-group">
                    <label asp-for="Amount">Amount ($)</label>
                    <input asp-for="Amount" class="form-control" />
                    <span asp-validation-for="Amount" class="text-danger"></span>
                </div>

                <div class="form-group">
                    <label asp-for="DateDue">Due Date</label>
                    <input asp-for="DateDue" class="form-control" />
                    <span asp-validation-for="DateDue" class="text-danger"></span>
                </div>

                <div class="form-group">
                    <label asp-for="PaymentMethod">Payment Method</label>
                    <select asp-for="PaymentMethod" class="form-control" asp-items="Html.GetEnumSelectList<JyoshinmonKarate.Models.PaymentMethods>()"></select>
                    <span asp-validation-for="PaymentMethod" class="text-danger"></span>
                </div>

                <div class="form-group">
                    <label asp-for="Status">Payment Status</label>
                    <select asp-for="Status" class="form-control" asp-items="Html.GetEnumSelectList<JyoshinmonKarate.Models.PaymentStatus>()"></select>
                    <span asp-validation-for="Status" class="text-danger"></span>
                </div>

            </div>

            <div class="form-actions">
                <button type="submit" class="save-btn">Create Payment</button>
                <a asp-action="Index" class="cancel-link">Cancel</a>
            </div>
        </form>

    </div>
</section>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}