@model JyoshinmonKarate.Models.Payment

@{
    ViewData["Title"] = "Payment Details";

    string memberName = Model.Member.FirstName + " " + Model.Member.LastName;
    string paymentMethod = Model.PaymentMethod.ToString();

    if (Model.PaymentMethod == JyoshinmonKarate.Models.PaymentMethods.CreditCard)
    {
        paymentMethod = "Credit Card";
    }
    else if (Model.PaymentMethod == JyoshinmonKarate.Models.PaymentMethods.BankTransfer)
    {
        paymentMethod = "Bank Transfer";
    }
    else if (Model.PaymentMethod == JyoshinmonKarate.Models.PaymentMethods.MobilePayment)
    {
        paymentMethod = "Mobile Payment";
    }
}

@section Styles {
    <link rel="stylesheet" href="~/css/payment.css" asp-append-version="true" />
}

<section class="payment-form-page">
    <div class="payment-form-card">

        <div class="payment-form-header">
            <h1>Payment Info</h1>
        </div>

        <div class="details-grid">

            <div class="details-item">
                <span>Member</span>
                <p>@memberName</p>
            </div>

            <div class="details-item">
                <span>Payment name</span>
                <p>@Model.PaymentName</p>
            </div>

            <div class="details-item">
                <span>Amount</span>
                <p>$@Model.Amount.ToString("0.00")</p>
            </div>

            <div class="details-item">
                <span>Due date</span>
                <p>@Model.DateDue.ToString("dd MMM yyyy")</p>
            </div>

            <div class="details-item">
                <span>Payment method</span>
                <p>@paymentMethod</p>
            </div>

            <div class="details-item">
                <span>Payment status</span>
                <p>@Model.Status</p>
            </div>

        </div>

        <div class="form-actions">
            <a asp-action="Edit" asp-route-id="@Model.PaymentId" class="save-link">Edit Payment</a>
            <a asp-action="Index" class="cancel-link">Back to List</a>
        </div>

    </div>
</section>