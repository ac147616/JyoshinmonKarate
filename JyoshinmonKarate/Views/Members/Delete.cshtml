@model JyoshinmonKarate.Models.Member

@{
    ViewData["Title"] = "Delete Member";

    string fullName = Model.FirstName + " " + Model.LastName;

    string beltName = "Not assigned";
    if (Model.Belt != null)
    {
        beltName = Model.Belt.BeltName;
    }

    string clubName = "Not assigned";
    if (Model.Club != null)
    {
        clubName = Model.Club.ClubName;
    }

    string userName = "Not assigned";
    if (Model.User != null)
    {
        userName = Model.User.Email;
    }
}

@section Styles {
    <link rel="stylesheet" href="~/css/member-delete.css" asp-append-version="true" />
}

<section class="delete-member-page">
    <div class="delete-member-card">

        <div class="delete-member-header">
            <h1>Delete Member</h1>
            <p>
                Please carefully review the member details below. Deleting this member will permanently remove them from the system.
            </p>
        </div>

        <div class="delete-member-profile">
            <div class="delete-photo-box">
                @if (!string.IsNullOrEmpty(Model.ProfilePhotoPath))
                {
                    <img src="@Url.Content(Model.ProfilePhotoPath)" alt="@fullName" />
                }
                else
                {
                    <i class="bi bi-person-fill"></i>
                }
            </div>

            <div>
                <h2>@fullName</h2>
                <p>@clubName</p>
            </div>
        </div>

        <div class="delete-details-grid">

            <div class="delete-detail-item">
                <span>First name</span>
                <p>@Model.FirstName</p>
            </div>

            <div class="delete-detail-item">
                <span>Last name</span>
                <p>@Model.LastName</p>
            </div>

            <div class="delete-detail-item">
                <span>Date of birth</span>
                <p>@Model.DateOfBirth.ToString("dd MMM yyyy")</p>
            </div>

            <div class="delete-detail-item">
                <span>Gender</span>
                <p>@Html.DisplayFor(model => model.Gender)</p>
            </div>

            <div class="delete-detail-item">
                <span>Weight</span>
                <p>@Model.Weight kg</p>
            </div>

            <div class="delete-detail-item">
                <span>Height</span>
                <p>@Model.Height cm</p>
            </div>

            <div class="delete-detail-item">
                <span>Club</span>
                <p>@clubName</p>
            </div>

            <div class="delete-detail-item">
                <span>Current belt</span>
                <p>@beltName</p>
            </div>

            <div class="delete-detail-item">
                <span>Belt size</span>
                <p>@Model.BeltSize</p>
            </div>

            <div class="delete-detail-item">
                <span>Status</span>
                <p class="status-text status-@Model.Status.ToString().ToLower()">
                    @Model.Status
                </p>
            </div>

            <div class="delete-detail-item">
                <span>Date joined</span>
                <p>@Model.DateJoined.ToString("dd MMM yyyy")</p>
            </div>

            <div class="delete-detail-item">
                <span>User account</span>
                <p>@userName</p>
            </div>

            <div class="delete-detail-item">
                <span>Emergency contact name</span>
                <p>@Model.EmergencyContactName</p>
            </div>

            <div class="delete-detail-item">
                <span>Emergency contact phone</span>
                <p>@Model.EmergencyContactPhone</p>
            </div>

        </div>

        <form asp-action="Delete" method="post" class="delete-actions">
            <input type="hidden" asp-for="MemberId" />

            <button type="submit" class="delete-confirm-btn">
                Delete Member
            </button>

            <a asp-action="Index" class="cancel-link">
                Cancel
            </a>
        </form>

    </div>
</section>