@model IEnumerable<JyoshinmonKarate.Models.Member>

@{
    ViewData["Title"] = "Members";
}

@section Styles {
    <link rel="stylesheet" href="~/css/member-index.css" asp-append-version="true" />
}

<section class="members-index-page">

    <div class="members-header">
        <h1>Members</h1>
    </div>

    <div class="members-toolbar">

        <div class="member-search-box">
            <input type="text" id="memberSearch" placeholder="Search members" />
        </div>

        <div class="member-toolbar-actions">

            <div class="status-filter-group">
                <button type="button" class="status-filter active" data-status="all">All</button>
                <button type="button" class="status-filter" data-status="active">Active</button>
            </div>

            <div class="more-filters-wrap">
                <button type="button" class="more-filters-btn" id="moreFiltersBtn">
                    <i class="bi bi-sliders"></i>
                    More filters
                </button>

                <div class="more-filters-panel" id="moreFiltersPanel">

                    <div class="filter-section">
                        <h3>Clubs</h3>

                        @foreach (var club in Model.Where(m => m.Club != null)
                                                                        .Select(m => m.Club.ClubName)
                                                                        .Distinct()
                                                                        .OrderBy(c => c))
                        {
                            <label>
                                <input type="checkbox" class="extra-filter" data-filter-type="club" value="@club.ToLower()" />
                                @club
                            </label>
                        }
                    </div>

                    <div class="filter-section">
                        <h3>Belts</h3>

                        @foreach (var belt in Model.Where(m => m.Belt != null)
                                                                        .Select(m => m.Belt.BeltName)
                                                                        .Distinct()
                                                                        .OrderBy(b => b))
                        {
                            <label>
                                <input type="checkbox" class="extra-filter" data-filter-type="belt" value="@belt.ToLower()" />
                                @belt
                            </label>
                        }
                    </div>

                    <div class="filter-section">
                        <h3>Age range</h3>

                        <label>
                            <input type="checkbox" class="extra-filter" data-filter-type="age" value="under16" />
                            Under 16
                        </label>

                        <label>
                            <input type="checkbox" class="extra-filter" data-filter-type="age" value="16to18" />
                            16 to 18
                        </label>

                        <label>
                            <input type="checkbox" class="extra-filter" data-filter-type="age" value="18plus" />
                            18+
                        </label>

                        <label>
                            <input type="checkbox" class="extra-filter" data-filter-type="age" value="35plus" />
                            35+
                        </label>
                    </div>

                    <div class="filter-section">
                        <h3>Gender</h3>

                        @{
                            var genders = Model.Select(m => m.Gender)
                                               .Distinct()
                                               .OrderBy(g => g.ToString());
                        }

                        @foreach (var gender in genders)
                        {
                            string genderValue = gender.ToString().ToLower();
                            string genderDisplay = gender.ToString();

                            if (gender == JyoshinmonKarate.Models.Gender.PreferNotToSay)
                            {
                                genderDisplay = "Prefer Not To Say";
                            }

                            <label>
                                <input type="checkbox"
                                       class="extra-filter"
                                       data-filter-type="gender"
                                       value="@genderValue" />
                                @genderDisplay
                            </label>
                        }
                    </div>

                    <button type="button" class="clear-filters-btn" id="clearFiltersBtn">
                        Clear filters
                    </button>

                </div>
            </div>

            <a asp-action="Create" class="add-member-btn">
                <i class="bi bi-plus-lg"></i>
                Add Member
            </a>

        </div>

    </div>

    <div class="members-table-wrap">

        <table class="members-table" id="membersTable">
            <thead>
                <tr>
                    <th>Member</th>
                    <th>Club</th>
                    <th>Belt</th>
                    <th>Status</th>
                    <th class="actions-heading">Actions</th>
                </tr>
            </thead>

            <tbody>
                @foreach (var item in Model)
                {
                    string fullName = item.FirstName + " " + item.LastName;

                    string clubName = "Not assigned";
                    if (item.Club != null)
                    {
                        clubName = item.Club.ClubName;
                    }

                    string beltName = "Not assigned";
                    if (item.Belt != null)
                    {
                        beltName = item.Belt.BeltName;
                    }

                    string statusName = item.Status.ToString();
                    string statusClass = statusName.ToLower();
                    string genderName = item.Gender.ToString().ToLower();

                    int age = 0;
                    DateTime today = DateTime.Today;

                    age = today.Year - item.DateOfBirth.Year;

                    if (item.DateOfBirth > today.AddYears(-age))
                    {
                        age--;
                    }

                    string ageGroup = "18plus";

                    if (age < 16)
                    {
                        ageGroup = "under16";
                    }
                    else if (age >= 16 && age <= 18)
                    {
                        ageGroup = "16to18";
                    }
                    else if (age >= 35)
                    {
                        ageGroup = "35plus";
                    }

                    <tr data-status="@statusClass"
                        data-club="@clubName.ToLower()"
                        data-belt="@beltName.ToLower()"
                        data-age="@ageGroup"
                        data-gender="@genderName">

                        <td>
                            <div class="member-profile-cell">

                                <div class="member-table-photo">
                                    @if (!string.IsNullOrEmpty(item.ProfilePhotoPath))
                                    {
                                        <img src="@Url.Content(item.ProfilePhotoPath)" alt="@fullName" />
                                    }
                                    else
                                    {
                                        <i class="bi bi-person-fill"></i>
                                    }
                                </div>

                                <span class="member-name">@fullName</span>

                            </div>
                        </td>

                        <td>@clubName</td>

                        <td>@beltName</td>

                        <td>
                            <span class="member-status status-@statusClass">
                                @statusName
                            </span>
                        </td>

                        <td>
                            <div class="member-actions">
                                <a asp-action="Details"
                                       asp-route-id="@item.MemberId"
                                       class="manage-member-link">
                                    Manage Member
                                </a>

                                <a asp-action="Delete"
                                       asp-route-id="@item.MemberId"
                                       class="delete-member-link">
                                    Delete
                                </a>
                            </div>
                        </td>
                    </tr>
                }
            </tbody>
        </table>

    </div>

    @if (ViewBag.TotalPages > 1)
    {
        <div class="app-pagination">

            @if (ViewBag.CurrentPage > 1)
            {
                <a asp-action="Index" asp-route-page="@(ViewBag.CurrentPage - 1)" class="app-page-link">&lt;</a>
            }
            else
            {
                <span class="app-page-link disabled">&lt;</span>
            }

            @for (int i = 1; i <= ViewBag.TotalPages; i++)
            {
                if (i == ViewBag.CurrentPage)
                {
                    <span class="app-page-link active">@i</span>
                }
                else
                {
                    <a asp-action="Index" asp-route-page="@i" class="app-page-link">@i</a>
                }
            }

            @if (ViewBag.CurrentPage < ViewBag.TotalPages)
            {
                <a asp-action="Index" asp-route-page="@(ViewBag.CurrentPage + 1)" class="app-page-link">&gt;</a>
            }
            else
            {
                <span class="app-page-link disabled">&gt;</span>
            }

        </div>
    }

</section>

@section Scripts {
    <script>
        const searchInput = document.getElementById("memberSearch");
        const rows = document.querySelectorAll("#membersTable tbody tr");
        const filterButtons = document.querySelectorAll(".status-filter");
        const extraFilters = document.querySelectorAll(".extra-filter");

        const moreFiltersBtn = document.getElementById("moreFiltersBtn");
        const moreFiltersPanel = document.getElementById("moreFiltersPanel");
        const clearFiltersBtn = document.getElementById("clearFiltersBtn");

        let selectedStatus = "all";

        function getSelectedStatusFromButton() {
            const activeButton = document.querySelector(".status-filter.active");

            if (activeButton) {
                return activeButton.getAttribute("data-status");
            }

            return "all";
        }

        function getCheckedValues(type) {
            return Array.from(extraFilters)
                .filter(filter => filter.checked && filter.getAttribute("data-filter-type") === type)
                .map(filter => filter.value);
        }

        function matchesSelectedFilter(row, type, selectedValues) {
            if (selectedValues.length === 0) {
                return true;
            }

            const rowValue = row.getAttribute("data-" + type);
            return selectedValues.includes(rowValue);
        }

        function filterMembers() {
            selectedStatus = getSelectedStatusFromButton();

            const searchValue = searchInput.value.toLowerCase();

            const selectedClubs = getCheckedValues("club");
            const selectedBelts = getCheckedValues("belt");
            const selectedAges = getCheckedValues("age");
            const selectedGenders = getCheckedValues("gender");

            rows.forEach(row => {
                const rowText = row.innerText.toLowerCase();
                const rowStatus = row.getAttribute("data-status");

                const matchesSearch = rowText.includes(searchValue);
                const matchesStatus = selectedStatus === "all" || rowStatus === selectedStatus;

                const matchesClub = matchesSelectedFilter(row, "club", selectedClubs);
                const matchesBelt = matchesSelectedFilter(row, "belt", selectedBelts);
                const matchesAge = matchesSelectedFilter(row, "age", selectedAges);
                const matchesGender = matchesSelectedFilter(row, "gender", selectedGenders);

                if (matchesSearch && matchesStatus && matchesClub && matchesBelt && matchesAge && matchesGender) {
                    row.style.display = "";
                } else {
                    row.style.display = "none";
                }
            });
        }

        searchInput.addEventListener("input", filterMembers);

        filterButtons.forEach(button => {
            button.addEventListener("click", function () {
                filterButtons.forEach(btn => btn.classList.remove("active"));
                this.classList.add("active");

                filterMembers();
            });
        });

        extraFilters.forEach(filter => {
            filter.addEventListener("change", filterMembers);
        });

        moreFiltersBtn.addEventListener("click", function () {
            moreFiltersPanel.classList.toggle("show");
        });

        clearFiltersBtn.addEventListener("click", function () {
            extraFilters.forEach(filter => filter.checked = false);
            searchInput.value = "";

            filterButtons.forEach(btn => btn.classList.remove("active"));

            const allButton = document.querySelector('.status-filter[data-status="all"]');
            if (allButton) {
                allButton.classList.add("active");
            }

            filterMembers();
        });

        document.addEventListener("click", function (event) {
            if (!event.target.closest(".more-filters-wrap")) {
                moreFiltersPanel.classList.remove("show");
            }
        });

        window.addEventListener("pageshow", function () {
            filterMembers();
        });

        filterMembers();
    </script>
}