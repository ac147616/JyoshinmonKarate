@model IEnumerable<JyoshinmonKarate.Models.Club>

@{
    ViewData["Title"] = "Dojos";
    bool isAdmin = User.IsInRole("Admin");
}

@section Styles {
    <link rel="stylesheet" href="~/css/dojo.css" asp-append-version="true" />
}

<section class="dojo-index-page">

    <div class="dojo-header-row">
        <div class="dojo-header">
            <h1>Dojos</h1>
        </div>

        @if (isAdmin)
        {
            <a asp-action="Create" class="add-dojo-btn">
                <i class="bi bi-plus-lg"></i>
                Add Dojo
            </a>
        }
    </div>

    <div class="dojo-table-wrap">
        <table class="dojo-table">
            <thead>
                <tr>
                    <th>Dojo Name</th>
                    <th>Address</th>
                    <th>Email</th>
                    <th>Phone</th>

                    @if (isAdmin)
                    {
                        <th class="actions-heading">Actions</th>
                    }
                </tr>
            </thead>

            <tbody>
                @foreach (var item in Model)
                {
                    <tr>
                        <td>
                            <span class="dojo-name">@item.ClubName</span>
                        </td>

                        <td>@item.Address</td>
                        <td>@item.Email</td>
                        <td>@item.Phone</td>

                        @if (isAdmin)
                        {
                            <td>
                                <div class="dojo-actions">
                                    <a asp-action="Details" asp-route-id="@item.ClubId" class="details-dojo-link">Details</a>
                                    <a asp-action="Edit" asp-route-id="@item.ClubId" class="edit-dojo-link">Edit</a>
                                    <a asp-action="Delete" asp-route-id="@item.ClubId" class="delete-dojo-link">Delete</a>
                                </div>
                            </td>
                        }
                    </tr>
                }
            </tbody>
        </table>
    </div>

</section>
