@model JyoshinmonKarate.Models.Club

@{
    ViewData["Title"] = "Dojo Details";
}

@section Styles {
    <link rel="stylesheet" href="~/css/dojo.css" asp-append-version="true" />
}

<section class="dojo-form-page">
    <div class="dojo-form-card">

        <div class="dojo-form-header">
            <h1>Dojo Info</h1>
        </div>

        <div class="details-grid">

            <div class="details-item">
                <span>Dojo name</span>
                <p>@Model.ClubName</p>
            </div>

            <div class="details-item">
                <span>Address</span>
                <p>@Model.Address</p>
            </div>

            <div class="details-item">
                <span>Email</span>
                <p>@Model.Email</p>
            </div>

            <div class="details-item">
                <span>Phone</span>
                <p>@Model.Phone</p>
            </div>

        </div>

        <div class="form-actions">
            <a asp-action="Edit" asp-route-id="@Model.ClubId" class="save-link">Edit Dojo</a>
            <a asp-action="Index" class="cancel-link">Back to List</a>
        </div>

    </div>
</section>
