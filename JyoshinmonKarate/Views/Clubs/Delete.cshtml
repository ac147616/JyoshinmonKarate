@model JyoshinmonKarate.Models.Club

@{
    ViewData["Title"] = "Delete Dojo";
}

@section Styles {
    <link rel="stylesheet" href="~/css/dojo.css" asp-append-version="true" />
}

<section class="dojo-form-page">
    <div class="dojo-form-card">

        <div class="dojo-form-header">
            <h1>Delete Dojo</h1>
            <p>Deleting this dojo will permanently remove it from the system.</p>
        </div>

        <div class="details-grid">

            <div class="details-item">
                <span>Dojo name</span>
                <p>@Model.ClubName</p>
            </div>

            <div class="details-item">
                <span>Address</span>
                <p>@Model.Address</p>
            </div>

            <div class="details-item">
                <span>Email</span>
                <p>@Model.Email</p>
            </div>

            <div class="details-item">
                <span>Phone</span>
                <p>@Model.Phone</p>
            </div>

        </div>

        <form asp-action="Delete" method="post" class="form-actions">
            <input type="hidden" asp-for="ClubId" />

            <button type="submit" class="delete-btn">Delete Dojo</button>
            <a asp-action="Index" class="cancel-link">Cancel</a>
        </form>

    </div>
</section>
