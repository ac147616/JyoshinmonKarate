@model JyoshinmonKarate.Models.Grading

@{
    ViewData["Title"] = "Create Grading";
}

@section Styles {
    <link rel="stylesheet" href="~/css/grading.css" asp-append-version="true" />
}

<section class="grading-form-page">
    <div class="grading-form-card">

        <div class="grading-form-header">
            <h1>Create Grading</h1>
        </div>

        <form asp-action="Create" method="post">
            <div asp-validation-summary="ModelOnly" class="text-danger"></div>

            <div class="form-grid">

                <div class="form-group">
                    <label asp-for="ClubId">Dojo</label>
                    <select asp-for="ClubId" class="form-control" asp-items="ViewBag.ClubId">
                        <option value="">Select a dojo</option>
                    </select>
                    <span asp-validation-for="ClubId" class="text-danger"></span>
                </div>

                <div class="form-group">
                    <label asp-for="GradingDate">Grading Date</label>
                    <input asp-for="GradingDate" class="form-control" />
                    <span asp-validation-for="GradingDate" class="text-danger"></span>
                </div>

                <div class="form-group">
                    <label asp-for="GradingStartTime">Start Time</label>
                    <input asp-for="GradingStartTime" class="form-control" />
                    <span asp-validation-for="GradingStartTime" class="text-danger"></span>
                </div>

                <div class="form-group">
                    <label asp-for="GradingEndTime">End Time</label>
                    <input asp-for="GradingEndTime" class="form-control" />
                    <span asp-validation-for="GradingEndTime" class="text-danger"></span>
                </div>

            </div>

            <div class="form-actions">
                <button type="submit" class="save-btn">Create Grading</button>
                <a asp-action="Index" class="cancel-link">Cancel</a>
            </div>
        </form>

    </div>
</section>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}