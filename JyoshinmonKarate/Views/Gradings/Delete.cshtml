@model JyoshinmonKarate.Models.Grading

@{
    ViewData["Title"] = "Delete Grading";
}

@section Styles {
    <link rel="stylesheet" href="~/css/grading.css" asp-append-version="true" />
}

<section class="grading-form-page">
    <div class="grading-form-card">

        <div class="grading-form-header">
            <h1>Delete Grading</h1>
            <p>Deleting this grading will permanently remove it from the system.</p>
        </div>

        <div class="details-grid">

            <div class="details-item">
                <span>Dojo</span>
                <p>@Model.Club.ClubName</p>
            </div>

            <div class="details-item">
                <span>Grading date</span>
                <p>@Model.GradingDate.ToString("dd MMM yyyy")</p>
            </div>

            <div class="details-item">
                <span>Start time</span>
                <p>@Model.GradingStartTime.ToString("hh:mm tt")</p>
            </div>

            <div class="details-item">
                <span>End time</span>
                <p>@Model.GradingEndTime.ToString("hh:mm tt")</p>
            </div>

        </div>

        <form asp-action="Delete" method="post" class="form-actions">
            <input type="hidden" asp-for="GradingId" />

            <button type="submit" class="delete-btn">Delete Grading</button>
            <a asp-action="Index" class="cancel-link">Cancel</a>
        </form>

    </div>
</section>
