@model IEnumerable<JyoshinmonKarate.Models.Attendance>

@{
    ViewData["Title"] = "Attendance";
    bool isAdmin = User.IsInRole("Admin");
}

@section Styles {
    <link rel="stylesheet" href="~/css/attendance.css" asp-append-version="true" />
}

<section class="attendance-index-page">

    <div class="attendance-header">
        <h1>Attendance</h1>
    </div>

    <form asp-action="Index" method="get" class="attendance-toolbar">

        <div class="attendance-filter-fields">

            <div class="attendance-filter-group">
                <label for="memberSearch">Member</label>

                <div class="member-search-select" id="memberSearchSelect">
                    <input type="text" id="memberSearch" placeholder="Search members" autocomplete="off" />
                    <input type="hidden" name="memberId" id="memberId" value="@ViewBag.SelectedMemberId" />

                    <div class="member-options" id="memberOptions">
                        <button type="button" class="member-option" data-value="0">All members</button>

                        @foreach (var member in ViewBag.MemberId)
                        {
                            <button type="button" class="member-option" data-value="@member.Value">@member.Text</button>
                        }
                    </div>
                </div>
            </div>

            <div class="attendance-filter-group attendance-schedule-filter">
                <label for="scheduleId">Class</label>
                <select name="scheduleId" id="scheduleId" asp-items="ViewBag.ScheduleId">
                    <option value="0">All classes</option>
                </select>
            </div>

            <div class="attendance-filter-group">
                <label for="startDate">From</label>
                <input type="date" name="startDate" id="startDate" value="@ViewBag.StartDate" />
            </div>

            <div class="attendance-filter-group">
                <label for="endDate">To</label>
                <input type="date" name="endDate" id="endDate" value="@ViewBag.EndDate" />
            </div>

            <div class="attendance-filter-actions">
                <button type="submit" class="apply-attendance-filters-btn">Apply</button>
                <a asp-action="Index" class="clear-attendance-filters-link">Clear</a>
            </div>

        </div>

        @if (isAdmin)
        {
            <a asp-action="Create" class="add-attendance-btn">
                <i class="bi bi-plus-lg"></i>
                Add Attendance
            </a>
        }

    </form>

    <div class="attendance-table-wrap">
        <table class="attendance-table">
            <thead>
                <tr>
                    <th>Member</th>
                    <th>Attendance Date</th>
                    <th>Dojo</th>
                    <th>Class</th>
                    <th>Time</th>

                    @if (isAdmin)
                    {
                        <th class="attendance-actions-heading">Actions</th>
                    }
                </tr>
            </thead>

            <tbody>
                @foreach (var item in Model)
                {
                    string memberName = item.Member.FirstName + " " + item.Member.LastName;
                    string className = item.Schedule.Level + " | " + item.Schedule.DayOfWeek;
                    string classTime = item.Schedule.StartTime.ToString("hh:mm tt") + " to " + item.Schedule.EndTime.ToString("hh:mm tt");

                    <tr>
                        <td>
                            <span class="attendance-member-name">@memberName</span>
                        </td>

                        <td>@item.Date.ToString("dd MMM yyyy")</td>
                        <td>@item.Schedule.Club.ClubName</td>
                        <td>@className</td>
                        <td>@classTime</td>

                        @if (isAdmin)
                        {
                            <td>
                                <div class="attendance-actions">
                                    <a asp-action="Details" asp-route-id="@item.AttendanceId" class="details-attendance-link">Details</a>
                                    <a asp-action="Edit" asp-route-id="@item.AttendanceId" class="edit-attendance-link">Edit</a>
                                    <a asp-action="Delete" asp-route-id="@item.AttendanceId" class="delete-attendance-link">Delete</a>
                                </div>
                            </td>
                        }
                    </tr>
                }
            </tbody>
        </table>
    </div>

    @if (!Model.Any())
    {
        <div class="attendance-empty-message">No attendance records were found.</div>
    }

    @if (ViewBag.TotalPages > 1)
    {
        <div class="app-pagination">

            @if (ViewBag.CurrentPage > 1)
            {
                <a asp-action="Index" asp-route-page="@(ViewBag.CurrentPage - 1)" asp-route-memberId="@ViewBag.SelectedMemberId" asp-route-scheduleId="@ViewBag.SelectedScheduleId" asp-route-startDate="@ViewBag.StartDate" asp-route-endDate="@ViewBag.EndDate" class="app-page-link">&lt;</a>
            }
            else
            {
                <span class="app-page-link disabled">&lt;</span>
            }

            @for (int i = 1; i <= ViewBag.TotalPages; i++)
            {
                if (i == ViewBag.CurrentPage)
                {
                    <span class="app-page-link active">@i</span>
                }
                else
                {
                    <a asp-action="Index" asp-route-page="@i" asp-route-memberId="@ViewBag.SelectedMemberId" asp-route-scheduleId="@ViewBag.SelectedScheduleId" asp-route-startDate="@ViewBag.StartDate" asp-route-endDate="@ViewBag.EndDate" class="app-page-link">@i</a>
                }
            }

            @if (ViewBag.CurrentPage < ViewBag.TotalPages)
            {
                <a asp-action="Index" asp-route-page="@(ViewBag.CurrentPage + 1)" asp-route-memberId="@ViewBag.SelectedMemberId" asp-route-scheduleId="@ViewBag.SelectedScheduleId" asp-route-startDate="@ViewBag.StartDate" asp-route-endDate="@ViewBag.EndDate" class="app-page-link">&gt;</a>
            }
            else
            {
                <span class="app-page-link disabled">&gt;</span>
            }

        </div>
    }

</section>

@section Scripts {
    <script>
        const memberSearchSelect = document.getElementById("memberSearchSelect")
        const memberSearch = document.getElementById("memberSearch");
        const memberId = document.getElementById("memberId");
        const memberOptions = document.getElementById("memberOptions");
        const memberOptionButtons = document.querySelectorAll(".member-option");

        function setSelectedMemberText() {
            const selectedValue = memberId.value;

            memberOptionButtons.forEach(option => {
                if (option.getAttribute("data-value") === selectedValue) {
                    memberSearch.value = option.innerText;
                }
            });
        }

        memberSearch.addEventListener("focus", function () {
            memberOptions.classList.add("show");
            this.select();
        });

        memberSearch.addEventListener("input", function () {
            const searchValue = this.value.toLowerCase();

            memberOptionButtons.forEach(option => {
                const optionText = option.innerText.toLowerCase();

                if (optionText.includes(searchValue)) {
                    option.style.display = "block";
                }
                else {
                    option.style.display = "none";
                }
            });

            memberOptions.classList.add("show");
        });

        memberOptionButtons.forEach(option => {
            option.addEventListener("click", function () {
                memberId.value = this.getAttribute("data-value");
                memberSearch.value = this.innerText;
                memberOptions.classList.remove("show");

                memberOptionButtons.forEach(button => {
                    button.style.display = "block";
                });
            });
        });

        document.addEventListener("click", function (event) {
            if (!event.target.closest("#memberSearchSelect")) {
                memberOptions.classList.remove("show");
            }
        });

        setSelectedMemberText();
    </script>
}