@model JyoshinmonKarate.Models.Attendance

@{
    ViewData["Title"] = "Create Attendance";
}

@section Styles {
    <link rel="stylesheet" href="~/css/attendance.css" asp-append-version="true" />
}

<section class="attendance-form-page">
    <div class="attendance-form-card">

        <div class="attendance-form-header">
            <h1>Create Attendance</h1>
        </div>

        <form asp-action="Create" method="post">
            <div asp-validation-summary="ModelOnly" class="text-danger"></div>

            <div class="form-grid">

                <div class="form-group">
                    <label asp-for="MemberId">Member</label>
                    <select asp-for="MemberId" class="form-control" asp-items="ViewBag.MemberId">
                        <option value="">Select a member</option>
                    </select>
                    <span asp-validation-for="MemberId" class="text-danger"></span>
                </div>

                <div class="form-group">
                    <label asp-for="ScheduleId">Class</label>
                    <select asp-for="ScheduleId" class="form-control" asp-items="ViewBag.ScheduleId">
                        <option value="">Select a class</option>
                    </select>
                    <span asp-validation-for="ScheduleId" class="text-danger"></span>
                </div>

                <div class="form-group">
                    <label asp-for="Date">Attendance Date</label>
                    <input asp-for="Date" class="form-control" />
                    <span asp-validation-for="Date" class="text-danger"></span>
                </div>

            </div>

            <div class="form-actions">
                <button type="submit" class="save-btn">Create Attendance</button>
                <a asp-action="Index" class="cancel-link">Cancel</a>
            </div>
        </form>

    </div>
</section>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}