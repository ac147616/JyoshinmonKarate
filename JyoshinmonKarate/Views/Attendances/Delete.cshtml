@model JyoshinmonKarate.Models.Attendance

@{
    ViewData["Title"] = "Delete Attendance";

    string memberName = Model.Member.FirstName + " " + Model.Member.LastName;
    string className = Model.Schedule.Level + " | " + Model.Schedule.DayOfWeek;
    string classTime = Model.Schedule.StartTime.ToString("hh:mm tt") + " to " + Model.Schedule.EndTime.ToString("hh:mm tt");
}

@section Styles {
    <link rel="stylesheet" href="~/css/attendance.css" asp-append-version="true" />
}

<section class="attendance-form-page">
    <div class="attendance-form-card">

        <div class="attendance-form-header">
            <h1>Delete Attendance</h1>
            <p>Deleting this attendance record will permanently remove it from the system.</p>
        </div>

        <div class="details-grid">

            <div class="details-item">
                <span>Member</span>
                <p>@memberName</p>
            </div>

            <div class="details-item">
                <span>Attendance date</span>
                <p>@Model.Date.ToString("dd MMM yyyy")</p>
            </div>

            <div class="details-item">
                <span>Dojo</span>
                <p>@Model.Schedule.Club.ClubName</p>
            </div>

            <div class="details-item">
                <span>Class</span>
                <p>@className</p>
            </div>

            <div class="details-item">
                <span>Class time</span>
                <p>@classTime</p>
            </div>

        </div>

        <form asp-action="Delete" method="post" class="form-actions">
            <input type="hidden" asp-for="AttendanceId" />

            <button type="submit" class="delete-btn">Delete Attendance</button>
            <a asp-action="Index" class="cancel-link">Cancel</a>
        </form>

    </div>
</section>