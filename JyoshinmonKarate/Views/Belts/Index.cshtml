@model IEnumerable<JyoshinmonKarate.Models.Belt>

@{
    ViewData["Title"] = "Belts";
    bool isAdmin = User.IsInRole("Admin");
}

@section Styles {
    <link rel="stylesheet" href="~/css/belt.css" asp-append-version="true" />
}

<section class="belt-index-page">

    <div class="belt-content">

        <div class="belt-header-row">
            <div class="belt-header">
                <h1>Belts</h1>
            </div>

            @if (isAdmin)
            {
                <a asp-action="Create" class="add-belt-btn">
                    <i class="bi bi-plus-lg"></i>
                    Add Belt
                </a>
            }
        </div>

        <div class="belt-table-wrap">
            <table class="belt-table">
                <thead>
                    <tr>
                        <th>Belt Name</th>

                        @if (isAdmin)
                        {
                            <th class="actions-heading">Actions</th>
                        }
                    </tr>
                </thead>

                <tbody>
                    @foreach (var item in Model)
                    {
                        <tr>
                            <td>
                                <span class="belt-name">@item.BeltName</span>
                            </td>

                            @if (isAdmin)
                            {
                                <td>
                                    <div class="belt-actions">
                                        <a asp-action="Details" asp-route-id="@item.BeltId" class="details-belt-link">Details</a>
                                        <a asp-action="Edit" asp-route-id="@item.BeltId" class="edit-belt-link">Edit</a>
                                        <a asp-action="Delete" asp-route-id="@item.BeltId" class="delete-belt-link">Delete</a>
                                    </div>
                                </td>
                            }
                        </tr>
                    }
                </tbody>
            </table>
        </div>

    </div>

</section>