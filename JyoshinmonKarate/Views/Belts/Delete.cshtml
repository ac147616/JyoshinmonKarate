@model JyoshinmonKarate.Models.Belt

@{
    ViewData["Title"] = "Delete Belt";
}

@section Styles {
    <link rel="stylesheet" href="~/css/belt.css" asp-append-version="true" />
}

<section class="belt-form-page">
    <div class="belt-form-card">

        <div class="belt-form-header">
            <h1>Delete Belt</h1>
            <p>Deleting this belt will permanently remove it from the system.</p>
        </div>

        <div class="details-grid">

            <div class="details-item">
                <span>Belt name</span>
                <p>@Model.BeltName</p>
            </div>

        </div>

        <form asp-action="Delete" method="post" class="form-actions">
            <input type="hidden" asp-for="BeltId" />

            <button type="submit" class="delete-btn">Delete Belt</button>
            <a asp-action="Index" class="cancel-link">Cancel</a>
        </form>

    </div>
</section>