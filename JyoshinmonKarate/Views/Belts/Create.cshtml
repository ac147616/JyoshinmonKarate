@model JyoshinmonKarate.Models.Belt

@{
    ViewData["Title"] = "Create Belt";
}

@section Styles {
    <link rel="stylesheet" href="~/css/belt.css" asp-append-version="true" />
}

<section class="belt-form-page">
    <div class="belt-form-card">

        <div class="belt-form-header">
            <h1>Create Belt</h1>
        </div>

        <form asp-action="Create" method="post">
            <div asp-validation-summary="All" class="text-danger"></div>

            <div class="form-grid">

                <div class="form-group">
                    <label asp-for="BeltName">Belt Name</label>
                    <input asp-for="BeltName" class="form-control" />
                    <span asp-validation-for="BeltName" class="text-danger"></span>
                </div>

            </div>

            <div class="form-actions">
                <button type="submit" class="save-btn">Create Belt</button>
                <a asp-action="Index" class="cancel-link">Cancel</a>
            </div>
        </form>

    </div>
</section>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}